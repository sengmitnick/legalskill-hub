# Production environment will check all required variables. Variables are optional if: 1) name ends with '_OPTIONAL' or 2) value uses ENV.fetch('CLACKY_xxx') pattern.

# CLACKY_XX variables, will be imported by Clacky CDE environments
# CLACKY_PREVIEW_DOMAIN_BASE
# CLACKY_EMAIL_SMTP_ADDRESS
# CLACKY_EMAIL_SMTP_PORT
# CLACKY_EMAIL_SMTP_USERNAME
# CLACKY_EMAIL_SMTP_API_KEY
# CLACKY_EMAIL_SMTP_DOMAIN
#
# DATABASE_URL will be setted in production, Rails will check it automatically!


# Use `rake secret` to generate one key
# production need!!!
SECRET_KEY_BASE: ''

# Set this value to generate email sending URLs and callback URLs
# production need!!!
PUBLIC_HOST: '<%= ENV.fetch('CLACKY_PUBLIC_HOST', '') %>'

# SMTP for email
EMAIL_SMTP_ADDRESS: '<%= ENV.fetch("CLACKY_EMAIL_SMTP_ADDRESS", '') %>'
EMAIL_SMTP_PORT: '<%= ENV.fetch("CLACKY_EMAIL_SMTP_PORT", '') %>'
EMAIL_SMTP_USERNAME: '<%= ENV.fetch("CLACKY_EMAIL_SMTP_USERNAME", '') %>'
EMAIL_SMTP_PASSWORD: '<%= ENV.fetch("CLACKY_EMAIL_API_KEY", '') %>'
EMAIL_SMTP_DOMAIN: '<%= ENV.fetch("CLACKY_EMAIL_SMTP_DOMAIN", '') %>'

# Storage bucket configuration, compatible with S3
STORAGE_BUCKET_ENDPOINT: '<%= ENV.fetch("CLACKY_STORAGE_BUCKET_ENDPOINT", '') %>'
STORAGE_BUCKET_ACCESS_KEY_ID: '<%= ENV.fetch("CLACKY_STORAGE_BUCKET_ACCESS_KEY_ID", '') %>'
STORAGE_BUCKET_SECRET_ACCESS_KEY: '<%= ENV.fetch("CLACKY_STORAGE_BUCKET_SECRET_ACCESS_KEY", '') %>'
STORAGE_BUCKET_REGION: '<%= ENV.fetch("CLACKY_STORAGE_BUCKET_REGION", '') %>'
STORAGE_BUCKET_NAME: '<%= ENV.fetch("CLACKY_STORAGE_BUCKET_NAME", '') %>'

# xxx_OPTIONAL is optional
# XXX_OPTIONAL: ''

# OAuth provider credentials generated by authentication generator
# Set enabled: 'true' to activate each OAuth provider (use strings to avoid Figaro warnings)
# Leave client id and secret blank to use Clacky Auth fallback

# Google OAuth
GOOGLE_OAUTH_ENABLED: '<%= ENV.fetch("CLACKY_GOOGLE_OAUTH_ENABLED", "false") %>'
GOOGLE_CLIENT_ID: '<%= ENV.fetch("CLACKY_AUTH_CLIENT_ID", "") %>'
GOOGLE_CLIENT_SECRET: '<%= ENV.fetch("CLACKY_AUTH_CLIENT_SECRET", "") %>'

# Facebook OAuth
FACEBOOK_OAUTH_ENABLED: '<%= ENV.fetch("CLACKY_FACEBOOK_OAUTH_ENABLED", "false") %>'
FACEBOOK_APP_ID: '<%= ENV.fetch("CLACKY_AUTH_CLIENT_ID", "") %>'
FACEBOOK_APP_SECRET: '<%= ENV.fetch("CLACKY_AUTH_CLIENT_SECRET", "") %>'

# Twitter OAuth
TWITTER_OAUTH_ENABLED: '<%= ENV.fetch("CLACKY_TWITTER_OAUTH_ENABLED", "false") %>'
TWITTER_API_KEY: '<%= ENV.fetch("CLACKY_AUTH_CLIENT_ID", "") %>'
TWITTER_API_SECRET: '<%= ENV.fetch("CLACKY_AUTH_CLIENT_SECRET", "") %>'

# GitHub OAuth
GITHUB_OAUTH_ENABLED: '<%= ENV.fetch("CLACKY_GITHUB_OAUTH_ENABLED", "false") %>'
GITHUB_CLIENT_ID: '<%= ENV.fetch("CLACKY_AUTH_CLIENT_ID", "") %>'
GITHUB_CLIENT_SECRET: '<%= ENV.fetch("CLACKY_AUTH_CLIENT_SECRET", "") %>'
# OAuth provider credentials generated end

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY: <%= ENV["CLACKY_STRIPE_PUBLISHABLE_KEY"] %>
STRIPE_SECRET_KEY: <%= ENV["CLACKY_STRIPE_SECRET_KEY"] %>
STRIPE_WEBHOOK_SECRET: <%= ENV["CLACKY_STRIPE_WEBHOOK_SECRET"] %>

# WeChat Open Platform (开放平台) credentials — used for PC QR code login (WxLogin)
WECHAT_OPEN_APPID: '<%= ENV.fetch("CLACKY_WECHAT_OPEN_APPID", "") %>'
WECHAT_OPEN_APPSECRET: '<%= ENV.fetch("CLACKY_WECHAT_OPEN_APPSECRET", "") %>'
WECHAT_OPEN_REDIRECT_URI: '<%= ENV.fetch("CLACKY_WECHAT_OPEN_REDIRECT_URI", "") %>'

# WeChat MP (公众号) credentials
WECHAT_MP_APPID: '<%= ENV.fetch("CLACKY_WECHAT_MP_APPID", "") %>'
WECHAT_MP_APPSECRET: '<%= ENV.fetch("CLACKY_WECHAT_MP_APPSECRET", "") %>'
WECHAT_MP_TOKEN: '<%= ENV.fetch("CLACKY_WECHAT_MP_TOKEN", "") %>'

# WeChat Pay (微信支付) credentials
WECHAT_PAY_MCH_ID: '<%= ENV.fetch("CLACKY_WECHAT_PAY_MCH_ID", "") %>'
WECHAT_PAY_API_V3_KEY: '<%= ENV.fetch("CLACKY_WECHAT_PAY_API_V3_KEY", "") %>'
WECHAT_PAY_CERT_PATH: '<%= Rails.root.join("certs") %>'
WECHAT_PAY_NOTIFY_URL: '<%= ENV.fetch("CLACKY_WECHAT_PAY_NOTIFY_URL", "") %>'
