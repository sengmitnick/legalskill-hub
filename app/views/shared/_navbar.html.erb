<!-- Tech Agent Navbar — Minimal dark command bar -->
<!-- DO NOT modify data-controller, data-action, or data-dropdown-target attributes -->

<div data-controller="dropdown" data-dropdown-close-on-click-outside-value="false">
  <nav class="bg-surface border-b border-border sticky top-0 z-40">
    <div class="container-xl mx-auto px-6">
      <div class="flex items-center justify-between h-14">

        <!-- Logo — geometric icon -->
        <div class="flex items-center gap-3">
          <%= link_to root_path, class: "flex items-center gap-2 group" do %>
            <div class="w-6 h-6 border border-primary flex items-center justify-center group-hover:border-primary-light transition-colors">
              <div class="w-2.5 h-2.5 bg-primary group-hover:bg-primary-light transition-colors"></div>
            </div>
            <span class="font-mono text-sm font-bold text-primary tracking-widest uppercase group-hover:text-primary-light transition-colors">
              青狮龙虾 QingClaw
            </span>
          <% end %>
          <span class="hidden md:inline text-border text-xs font-mono select-none">|</span>
          <span class="hidden md:inline text-muted text-xs font-mono tracking-widest">律师 AI 助手</span>
        </div>

        <!-- Desktop navigation -->
        <div class="hidden md:flex items-center gap-6">
          <%= render 'shared/nav_links' %>
        </div>

        <!-- Desktop auth -->
        <div class="hidden md:flex items-center gap-3">
          <% if current_user %>
            <%= render 'shared/user_dropdown' %>
          <% else %>
            <%= link_to sign_in_path, class: "btn-primary btn-sm font-mono text-sm tracking-widest" do %>
              微信登录
            <% end %>
          <% end %>
        </div>

        <!-- Mobile hamburger - DO NOT REMOVE -->
        <button type="button"
                data-action="click->dropdown#toggle"
                class="md:hidden p-2 text-secondary hover:text-primary border border-transparent hover:border-border transition-all">
          <%= lucide_icon "menu", class: "w-5 h-5" %>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile drawer - DO NOT REMOVE this structure -->
  <div data-dropdown-target="menu" class="hidden fixed inset-0 z-50 md:hidden">
    <!-- Background overlay -->
    <div class="fixed inset-0 bg-black/70 backdrop-blur-sm" data-action="click->dropdown#close"></div>

    <!-- Drawer content — dark panel -->
    <div class="fixed right-0 top-0 h-full w-64 bg-surface-elevated border-l border-border overflow-y-auto">
      <div class="p-5">
        <!-- Close button -->
        <button type="button"
                data-action="click->dropdown#close"
                class="mb-6 p-1.5 hover:text-primary text-secondary border border-transparent hover:border-border transition-all">
          <%= lucide_icon "x", class: "w-5 h-5" %>
        </button>

        <div class="mb-2 text-xs font-mono text-muted tracking-widest uppercase">导航菜单</div>
        <!-- Mobile navigation -->
        <div class="mb-6 flex flex-col gap-1">
          <%= render 'shared/nav_links' %>
        </div>

        <!-- Mobile user menu -->
        <div class="border-t border-border pt-4">
          <% if current_user %>
            <%= render 'shared/user_dropdown' %>
          <% else %>
            <%= link_to sign_in_path, class: "btn-primary btn-md w-full font-mono text-xs tracking-widest inline-flex items-center justify-center gap-1.5" do %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                <path d="M8.5 4a6.5 6.5 0 0 0-1.56 12.81C7.3 17 7.5 17.16 7.5 17.5v.5a.5.5 0 0 0 .72.45l1.5-.75a1 1 0 0 1 .45-.1 8.56 8.56 0 0 0 1.33.1C11.5 17.7 11 16.9 11 16c0-2.76 2.69-5 6-5 .34 0 .67.02 1 .07A6.5 6.5 0 0 0 8.5 4z"/>
                <path d="M17 13c-2.21 0-4 1.57-4 3.5S14.79 20 17 20a5.4 5.4 0 0 0 1.08-.11.5.5 0 0 1 .35.06l1.07.54a.3.3 0 0 0 .43-.32l-.2-.9a.5.5 0 0 1 .14-.46C20.55 18.33 21 17.45 21 16.5 21 14.57 19.21 13 17 13z"/>
              </svg>
              <span>微信登录</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
