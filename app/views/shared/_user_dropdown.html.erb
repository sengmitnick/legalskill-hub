<!-- User dropdown menu - Powered by dropdown_controller.ts -->
<div data-controller="dropdown" class="relative">
  <!-- Dropdown trigger button -->
  <button type="button"
          data-dropdown-target="trigger"
          data-action="click->dropdown#toggle"
          class="w-full md:w-auto flex items-center justify-start space-x-2 px-3 py-2 text-secondary hover:text-primary border border-transparent hover:border-border rounded transition-all">
    <!-- User avatar -->
    <div class="w-7 h-7 bg-primary flex items-center justify-center text-surface text-xs font-mono font-bold">
      <%= current_user.name&.first&.upcase || 'U' %>
    </div>
    <!-- User name -->
    <span class="text-sm font-mono flex-1 text-left truncate max-w-[100px]">
      <%= current_user.name || "用户" %>
    </span>
    <!-- Dropdown arrow -->
    <svg class="w-3 h-3 flex-shrink-0 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>

  <!-- Dropdown menu -->
  <div data-dropdown-target="menu"
       class="hidden absolute right-0 mt-2 w-60 bg-surface-elevated border border-border z-50 overflow-hidden shadow-xl">
    <!-- User info header -->
    <div class="px-5 py-4 border-b border-border">
      <p class="text-sm font-mono font-bold text-primary truncate">
        <%= current_user.name || "用户" %>
      </p>
      <p class="text-xs font-mono text-muted truncate mt-1">
        <%= current_user.wechat_openid.present? ? "微信账号" : current_user.email %>
      </p>
    </div>

    <!-- Menu items -->
    <div class="py-2">
      <%= link_to profile_path, class: "flex items-center gap-3 px-5 py-3 text-sm font-mono text-secondary hover:text-primary hover:bg-surface transition-colors" do %>
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
        </svg>
        个人资料
      <% end %>
      <%= link_to orders_path, class: "flex items-center gap-3 px-5 py-3 text-sm font-mono text-secondary hover:text-primary hover:bg-surface transition-colors" do %>
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        我的订单
      <% end %>
      <%= link_to my_tools_path, class: "flex items-center gap-3 px-5 py-3 text-sm font-mono text-secondary hover:text-primary hover:bg-surface transition-colors" do %>
        <%= lucide_icon "key", class: "w-4 h-4 shrink-0" %>
        我的工具
      <% end %>
    </div>

    <!-- Sign out -->
    <div class="border-t border-border py-2">
      <%= button_to sign_out_path, method: :delete,
            class: "flex items-center gap-3 w-full text-left px-5 py-3 text-sm font-mono text-red-400 hover:text-red-300 hover:bg-surface transition-colors" do %>
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
        </svg>
        退出登录
      <% end %>
    </div>
  </div>
</div>
