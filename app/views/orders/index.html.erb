<% content_for :title, "我的订单" %>

<div class="min-h-screen bg-surface pt-20 pb-16">
  <div class="max-w-3xl mx-auto px-4">

    <!-- 页头 -->
    <div class="mb-8">
      <h1 class="text-2xl font-mono font-bold text-primary">我的订单</h1>
      <p class="text-sm font-mono text-muted mt-1">共 <%= @orders.count %> 条记录</p>
    </div>

    <% if @orders.empty? %>
      <!-- 空状态 -->
      <div class="border border-border p-12 text-center">
        <svg class="w-12 h-12 text-muted mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <p class="text-muted font-mono text-sm">暂无订单</p>
        <%= link_to "去看看课程", root_path, class: "inline-block mt-4 text-xs font-mono text-accent hover:underline" %>
      </div>

    <% else %>
      <!-- 订单列表 -->
      <div class="space-y-3">
        <% @orders.each do |order| %>
          <div class="border border-border bg-surface-elevated p-5">
            <!-- 顶部：描述 + 状态 -->
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <p class="text-sm font-mono font-bold text-primary leading-snug">
                  <%= order.display_description %>
                </p>
                <p class="text-xs font-mono text-muted mt-1">
                  订单号：<span class="text-secondary"><%= order.out_trade_no %></span>
                </p>
              </div>
              <!-- 状态标签 -->
              <% status_class = case order.status
                 when "paid"    then "text-green-400 border-green-400/40 bg-green-400/10"
                 when "pending" then "text-yellow-400 border-yellow-400/40 bg-yellow-400/10"
                 when "failed"  then "text-red-400 border-red-400/40 bg-red-400/10"
                 else                "text-muted border-border bg-surface"
                 end
              %>
              <% status_text = case order.status
                 when "paid"    then "已支付"
                 when "pending" then "待支付"
                 when "failed"  then "支付失败"
                 when "closed"  then "已关闭"
                 else order.status
                 end
              %>
              <span class="flex-shrink-0 text-xs font-mono px-2 py-1 border rounded <%= status_class %>">
                <%= status_text %>
              </span>
            </div>

            <!-- 底部：金额 + 时间 -->
            <div class="flex items-center justify-between pt-4 border-t border-border">
              <div class="flex items-center gap-4 text-xs font-mono text-muted">
                <span>下单时间：<%= order.created_at.strftime("%Y-%m-%d %H:%M") %></span>
                <% if order.quantity.present? && order.quantity > 1 %>
                  <span>× <%= order.quantity %> 人</span>
                <% end %>
              </div>
              <p class="text-lg font-mono font-bold text-primary">
                ¥<%= order.amount %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
