<% content_for :title, "我的订单" %>

<div class="container-lg py-12">
  <!-- Page Title -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold font-mono text-primary">我的订单</h1>
    <p class="text-secondary font-mono mt-2">共 <%= @orders.count %> 条记录</p>
  </div>

  <% if @orders.empty? %>
    <div class="card">
      <div class="card-body py-16 text-center">
        <svg class="w-12 h-12 text-muted mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <p class="text-muted font-mono text-sm">暂无订单</p>
        <%= link_to "去看看课程", root_path, class: "inline-block mt-4 text-xs font-mono text-accent hover:underline" %>
      </div>
    </div>

  <% else %>
    <div class="space-y-4">
      <% @orders.each do |order| %>
        <div class="card" style="border-color: hsl(220 16% 28%)">
          <div class="card-body">
            <!-- 标题行：描述 + 状态 -->
            <div class="flex items-start justify-between gap-4 mb-6">
              <h2 class="text-lg font-semibold font-mono text-primary leading-snug">
                <%= order.display_description %>
              </h2>
              <% status_class = case order.status
                 when "paid"    then "text-green-400 border-green-400/40 bg-green-400/10"
                 when "pending" then "text-yellow-400 border-yellow-400/40 bg-yellow-400/10"
                 when "failed"  then "text-red-400 border-red-400/40 bg-red-400/10"
                 else                "text-muted border-border bg-surface"
                 end
              %>
              <% status_text = case order.status
                 when "paid"    then "已支付"
                 when "pending" then "待支付"
                 when "failed"  then "支付失败"
                 when "closed"  then "已关闭"
                 else order.status
                 end
              %>
              <span class="flex-shrink-0 text-xs font-mono px-2 py-1 border rounded <%= status_class %>">
                <%= status_text %>
              </span>
            </div>

            <!-- 详细信息 -->
            <div class="space-y-4">
              <div>
                <label class="form-label">订单号</label>
                <div class="text-muted font-mono text-xs"><%= order.out_trade_no %></div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="form-label">支付金额</label>
                  <div class="text-primary font-mono font-medium">¥<%= order.amount %></div>
                </div>
                <div>
                  <label class="form-label">下单时间</label>
                  <div class="text-primary font-mono font-medium"><%= order.created_at.in_time_zone("Beijing").strftime("%Y-%m-%d %H:%M") %></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
