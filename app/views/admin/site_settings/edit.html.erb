<% content_for :title do %>
  网站设置
<% end %>

<div class="container-xl">
  <div class="text-sm text-gray-600 dark:text-gray-300 mb-6">
    <ol class="flex space-x-2">
      <li><%= link_to "控制台", admin_root_path, class: "text-blue-600 hover:text-blue-800 dark:text-blue-400" %></li>
      <li class="text-gray-400">/</li>
      <li>网站设置</li>
    </ol>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
        <div class="card-body">
          <h2 class="text-2xl font-semibold mb-6 flex items-center text-gray-900 dark:text-gray-100">
            <%= lucide_icon "settings", class: "w-6 h-6 mr-2" %>
            首页引导视频
          </h2>

          <%= form_with url: admin_site_settings_path, method: :patch, class: "space-y-6" do |f| %>
            <% @settings.each do |setting| %>
              <div class="form-group">
                <label class="form-label font-medium"><%= setting[:label] %></label>
                <input
                  type="text"
                  name="site_settings[<%= setting[:key] %>]"
                  value="<%= setting[:value] %>"
                  placeholder="<%= setting[:key] == 'hero_video_url' ? 'https://your-bucket.qiniudn.com/video.mp4' : '视频标题，如：青狮龙虾 3 分钟快速上手' %>"
                  class="form-control w-full"
                />
                <% if setting[:key] == "hero_video_url" %>
                  <p class="form-help text-xs text-gray-500 mt-1">粘贴七牛云视频的 mp4 直链，留空则首页不显示「观看演示」按钮</p>
                <% end %>
              </div>
            <% end %>

            <div class="flex items-center justify-end space-x-4">
              <%= link_to admin_root_path, class: "btn-ghost" do %>
                <%= lucide_icon "x", class: "w-4 h-4 mr-2" %>
                取消
              <% end %>
              <%= f.submit "保存设置", class: "btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- 说明卡片 -->
    <div>
      <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
        <div class="card-body">
          <h2 class="text-xl font-semibold mb-4 flex items-center text-gray-900 dark:text-gray-100">
            <%= lucide_icon "info", class: "w-5 h-5 mr-2" %>
            使用说明
          </h2>
          <div class="space-y-3 text-sm text-gray-600 dark:text-gray-300">
            <p>1. 将视频上传到七牛云对象存储</p>
            <p>2. 复制视频的公开访问链接（mp4 直链）</p>
            <p>3. 粘贴到上方「视频链接」输入框</p>
            <p>4. 保存后首页 Hero 区会显示「▶ 观看演示」按钮</p>
            <p class="text-yellow-600 dark:text-yellow-400">⚠ 链接留空则按钮自动隐藏</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
