<% content_for :title, "站点配置" %>

<div class="container-xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-50">站点配置</h1>
    <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">管理首页安装/卸载命令及其他站点文本</p>
  </div>

  <% if notice.present? %>
    <div class="mb-4 px-4 py-3 rounded-lg bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 text-green-800 dark:text-green-300 text-sm">
      <%= notice %>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 text-red-800 dark:text-red-300 text-sm">
      <%= alert %>
    </div>
  <% end %>

  <div class="flex flex-col gap-4">
    <% @settings.each do |s| %>
      <div class="card bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-5">
        <div class="mb-2 flex items-center gap-2">
          <code class="text-xs font-mono px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400"><%= s[:key] %></code>
        </div>
        <%= form_with url: update_admin_site_settings_path(s[:key]), method: :patch, class: "flex gap-3 items-start" do |f| %>
          <%= f.hidden_field :key, value: s[:key] %>
          <% if s[:value].to_s.length > 80 %>
            <%= f.text_area :value, value: s[:value],
                rows: 3,
                class: "flex-1 font-mono text-sm rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500",
                placeholder: "（空）" %>
          <% else %>
            <%= f.text_field :value, value: s[:value],
                class: "flex-1 font-mono text-sm rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500",
                placeholder: "（空）" %>
          <% end %>
          <%= f.submit "保存", class: "shrink-0 px-4 py-2 text-sm font-medium rounded-lg bg-blue-600 hover:bg-blue-700 text-white cursor-pointer transition-colors" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
