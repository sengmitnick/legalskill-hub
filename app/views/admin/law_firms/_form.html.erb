<%= form_with model: [:admin, law_firm], class: "space-y-6", data: { controller: "profile-edit" } do |f| %>
  <% if law_firm.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-4 text-sm text-red-700">
      <% law_firm.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <label class="form-label">律所名称 <span class="text-red-500">*</span></label>
    <%= f.text_field :name, class: "form-input w-full", placeholder: "如：北京大成律师事务所" %>
  </div>

  <div>
    <label class="form-label">所在地区</label>
    <div class="grid grid-cols-3 gap-2">
      <select name="law_firm[province]"
              data-profile-edit-target="province"
              data-selected="<%= law_firm.province %>"
              data-action="change->profile-edit#onProvinceChange"
              class="form-input">
        <option value="">请选择省</option>
      </select>
      <select name="law_firm[city]"
              data-profile-edit-target="city"
              data-selected="<%= law_firm.city %>"
              data-action="change->profile-edit#onCityChange"
              class="form-input">
        <option value="">请选择市</option>
      </select>
      <select name="law_firm[district]"
              data-profile-edit-target="district"
              data-selected="<%= law_firm.district %>"
              class="form-input">
        <option value="">请选择区/县</option>
      </select>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit law_firm.new_record? ? "创建律所" : "保存修改", class: "btn-primary" %>
    <%= link_to "取消", admin_law_firms_path, class: "btn-ghost" %>
  </div>
<% end %>
