<% content_for :title, "班次报名详情" %>

<div class="container-xl">
  <div class="mb-6 flex items-center justify-between">
    <%= link_to "← 返回班次列表", admin_offline_classes_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <%= link_to "编辑班次", edit_admin_offline_class_path(@offline_class), class: "btn-sm btn-outline" %>
  </div>

  <!-- 班次信息 -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 mb-6">
    <div class="card-body">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-50 mb-4"><%= @offline_class.title %></h1>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
        <div>
          <span class="text-gray-500">日期</span>
          <p class="font-mono font-medium"><%= @offline_class.date.strftime("%Y-%m-%d") %></p>
        </div>
        <div>
          <span class="text-gray-500">城市</span>
          <p class="font-medium"><%= @offline_class.city %></p>
        </div>
        <div>
          <span class="text-gray-500">地点</span>
          <p class="font-medium"><%= @offline_class.location %></p>
        </div>
        <div>
          <span class="text-gray-500">报名 / 名额</span>
          <p class="font-mono font-bold <%= @offline_class.full? ? 'text-red-500' : 'text-green-600' %>">
            <%= @offline_class.attendees_count %> / <%= @offline_class.capacity %>
          </p>
        </div>
      </div>
      <% if @offline_class.description.present? %>
        <p class="mt-4 text-sm text-gray-500"><%= @offline_class.description %></p>
      <% end %>
    </div>
  </div>

  <!-- 报名列表 -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body p-0">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">报名记录（<%= @enrollments.count %>条）</h2>
      </div>
      <% if @enrollments.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">用户</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">手机号</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">报名人数</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">报名时间</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
              <% @enrollments.each do |enrollment| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                      <%= enrollment.user.name.presence || enrollment.user.email %>
                    </div>
                    <div class="text-xs text-gray-400"><%= enrollment.user.email %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900 dark:text-gray-100">
                    <%= enrollment.user.profile&.phone.presence || "—" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <span class="font-mono font-bold text-lg text-gray-900 dark:text-gray-100">
                      <%= enrollment.attendee_count %> 人
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= enrollment.created_at.in_time_zone("Beijing").strftime("%Y-%m-%d %H:%M") %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-10 text-gray-400">暂无报名记录</div>
      <% end %>
    </div>
  </div>
</div>
