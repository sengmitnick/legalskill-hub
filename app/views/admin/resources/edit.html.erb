<% content_for :title, "编辑资源" %>

<div class="container-md">
  <div class="flex items-center space-x-4">
    <%= link_to admin_resources_path, class: "btn-ghost text-sm py-1 px-3" do %>
      <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
      ← 返回资源列表
    <% end %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mt-4 mb-8">编辑资源</h1>

  <!-- Form -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <%= form_with model: [:admin, @resource], local: true, class: "space-y-6" do |form| %>
        <!-- Title -->
        <div class="form-group">
          <%= form.label :title, "标题" %>
          <%= form.text_field :title, placeholder: "请输入资源标题..." %>
        </div>

        <!-- Url -->
        <div class="form-group">
          <%= form.label :url, "链接地址" %>
          <%= form.text_field :url, placeholder: "请输入完整URL (https://...)" %>
        </div>

        <!-- Resource tag -->
        <div class="form-group">
          <%= form.label :resource_tag, "资源分类" %>
          <%= form.select :resource_tag, 
                options_for_select([['请选择分类', '']] + Resource::RESOURCE_TAG_NAMES.map { |k, v| [v, k] }, @resource.resource_tag),
                {}, 
                class: "form-select" %>
        </div>

        <!-- Resource type (hidden, always website) -->
        <%= form.hidden_field :resource_type, value: "website" %>

        <!-- Description -->
        <div class="form-group">
          <%= form.label :description, "描述" %>
          <%= form.text_area :description, rows: 5, placeholder: "请输入资源描述（可选）..." %>
        </div>

        <!-- Position -->
        <div class="form-group">
          <%= form.label :position, "排序" %>
          <%= form.number_field :position, placeholder: "数字越小越靠前" %>
        </div>

        <!-- Published -->
        <div class="form-group">
          <label class="flex items-center cursor-pointer">
            <%= form.check_box :published,
                  class: "mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 dark:border-gray-600 rounded dark:bg-gray-700" %>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">发布到登录页</span>
          </label>
        </div>

        <!-- Form Actions -->
        <div class="flex justify-end space-x-3">
          <%= link_to admin_resource_path(@resource.id), class: "btn-ghost" do %>
            取消
          <% end %>
          <%= form.submit "保存修改", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
