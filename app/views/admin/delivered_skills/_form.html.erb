<%= form_with model: [:admin, delivered_skill], local: true, class: "space-y-6" do |f| %>
  <% if delivered_skill.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
      <ul class="list-disc list-inside text-sm text-red-600 dark:text-red-400 space-y-1">
        <% delivered_skill.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- 技能名称 -->
  <div>
    <%= f.label :name, "技能名称", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :name,
        placeholder: "如：AI 合同审核 Word 版",
        class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
  </div>

  <!-- 场景 -->
  <div>
    <%= f.label :scenario, "使用场景", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_area :scenario,
        rows: 3,
        placeholder: "描述该技能适用的工作场景，如：合同审核、文书撰写…",
        class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
  </div>

  <!-- 节约时间 -->
  <div>
    <%= f.label :time_saved, "节约的时间", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :time_saved,
        placeholder: "如：3 小时、2h/份",
        class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">等值价值将自动按 2000 元/小时计算</p>
  </div>

  <!-- 视频演示 URL -->
  <div>
    <%= f.label :demo_video_url, "视频演示链接（可选）", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.url_field :demo_video_url,
        placeholder: "https://www.bilibili.com/video/...",
        class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">填写后首页该技能行会显示「观看演示」按钮</p>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
    <%= f.submit delivered_skill.new_record? ? "创建技能" : "保存修改",
        class: "btn-primary cursor-pointer" %>
    <%= link_to "取消", admin_delivered_skills_path,
        class: "px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors" %>
  </div>
<% end %>
