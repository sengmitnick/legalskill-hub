<%# LOGIN — Tech Agent dark terminal panel %>
<div class="min-h-screen bg-surface tech-grid-bg flex items-center justify-center px-4">
  <!-- Glow -->
  <div class="fixed inset-0 pointer-events-none"
       style="background: radial-gradient(ellipse 60% 50% at 50% 30%, hsl(174 100% 44% / 0.05) 0%, transparent 70%);"></div>

  <div class="relative w-full max-w-md">
    <!-- Panel header -->
    <div class="bg-surface-elevated border border-border border-b-0 px-6 py-4 flex items-center gap-3">
      <div class="flex gap-1.5">
        <div class="w-2.5 h-2.5 rounded-full bg-border"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-border"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-primary/60"></div>
      </div>
      <span class="font-mono text-xs text-muted tracking-widest">认证 :: 登录</span>
    </div>

    <!-- Panel body -->
    <div class="bg-surface-elevated border border-border p-8">
      <div class="mb-8">
        <div class="sys-label mb-2">// 身份验证</div>
        <h1 class="font-mono text-xl font-bold text-primary">登录</h1>
      </div>

      <%= form_with(model: User.new, url: sign_in_path, class: "space-y-5") do |form| %>
        <div>
          <label class="block text-xs font-mono text-muted tracking-wider mb-1.5 uppercase">邮箱</label>
          <%= form.email_field :email,
                value: params[:email_hint],
                required: true, autofocus: true,
                autocomplete: "email",
                placeholder: "user@domain.com",
                class: "form-input w-full bg-surface border-border font-mono text-sm placeholder:text-muted/50 focus:border-primary" %>
        </div>

        <div>
          <label class="block text-xs font-mono text-muted tracking-wider mb-1.5 uppercase">密码</label>
          <%= form.password_field :password,
                required: true,
                autocomplete: "current-password",
                placeholder: "••••••••",
                class: "form-input w-full bg-surface border-border font-mono text-sm placeholder:text-muted/50 focus:border-primary" %>
        </div>

        <div class="pt-2">
          <%= form.submit "立即登录 →", class: "btn-primary w-full btn-lg font-mono text-xs tracking-widest" %>
        </div>
      <% end %>

      <!-- Divider -->
      <div class="tech-divider my-6">或</div>

      <% if @privacy_iframe_mode %>
        <div class="alert alert-danger mb-4 font-mono text-xs">
          检测到隐私模式。登录可能无法正常工作。请在新窗口中打开。
        </div>
      <% end %>

      <!-- OAuth options -->
      <div class="space-y-2">
        <% if ENV['GOOGLE_OAUTH_ENABLED'] == 'true' %>
          <%= button_to "/auth/google_oauth2", method: :post, class: "btn-ghost w-full flex items-center justify-center gap-2 font-mono text-xs tracking-wider", data: { turbo: false, disable_with: "AUTHENTICATING..." }, form: { onsubmit: "this.target = (window.self !== window.parent) ? '_blank' : '_self';" } do %>
            <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            继续使用 GOOGLE
          <% end %>
        <% end %>

        <% if ENV['GITHUB_OAUTH_ENABLED'] == 'true' %>
          <%= button_to "/auth/github", method: :post, class: "btn-ghost w-full flex items-center justify-center gap-2 font-mono text-xs tracking-wider", data: { turbo: false, disable_with: "AUTHENTICATING..." }, form: { onsubmit: "this.target = (window.self !== window.parent) ? '_blank' : '_self';" } do %>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            继续使用 GITHUB
          <% end %>
        <% end %>

        <% if ENV['FACEBOOK_OAUTH_ENABLED'] == 'true' %>
          <%= button_to "/auth/facebook", method: :post, class: "btn-ghost w-full flex items-center justify-center gap-2 font-mono text-xs tracking-wider", data: { turbo: false, disable_with: "AUTHENTICATING..." }, form: { onsubmit: "this.target = (window.self !== window.parent) ? '_blank' : '_self';" } do %>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            继续使用 FACEBOOK
          <% end %>
        <% end %>

        <% if ENV['TWITTER_OAUTH_ENABLED'] == 'true' %>
          <%= button_to "/auth/twitter2", method: :post, class: "btn-ghost w-full flex items-center justify-center gap-2 font-mono text-xs tracking-wider", data: { turbo: false, disable_with: "AUTHENTICATING..." }, form: { onsubmit: "this.target = (window.self !== window.parent) ? '_blank' : '_self';" } do %>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
            继续使用 TWITTER
          <% end %>
        <% end %>
      </div>

      <!-- WeChat QR Login -->
      <div class="tech-divider my-6">微信扫码登录</div>

      <div data-controller="wechat-login"
           class="flex flex-col items-center gap-3 py-2">

        <%# QR code image %>
        <div class="relative w-40 h-40 border border-border bg-surface flex items-center justify-center">
          <%# Loading spinner (shown until QR loads) %>
          <div data-wechat-login-target="loadingSpinner"
               class="absolute inset-0 flex items-center justify-center">
            <div class="w-6 h-6 border-2 border-primary/30 border-t-primary rounded-full animate-spin"></div>
          </div>

          <img data-wechat-login-target="qrImage"
               src=""
               alt="微信登录二维码"
               class="hidden w-full h-full object-contain" />
        </div>

        <%# Status text %>
        <p data-wechat-login-target="status"
           class="font-mono text-xs text-muted text-center">正在生成二维码…</p>

        <%# Countdown %>
        <p class="font-mono text-xs text-muted/60">
          二维码有效期：<span data-wechat-login-target="countdown" class="text-primary">60s</span>
        </p>

        <%# Refresh button (hidden until expired) %>
        <button data-wechat-login-target="refreshBtn"
                data-action="click->wechat-login#refresh"
                class="hidden btn-ghost btn-sm font-mono text-xs tracking-wider">
          刷新二维码
        </button>
      </div>

      <!-- Footer links -->
      <div class="mt-8 pt-6 border-t border-border flex items-center justify-between text-xs font-mono text-muted">
        <%= link_to "忘记密码", new_identity_password_reset_path, class: "hover:text-primary transition-colors tracking-wider" %>
        <%= link_to "→ 注册账号", sign_up_path, class: "hover:text-primary transition-colors tracking-wider text-primary/70" %>
      </div>
    </div>
  </div>
</div>
