<% content_for :turbo_cache do %><meta name="turbo-cache-control" content="no-cache"><% end %>
<%# LOGIN — 微信扫码登录 %>
<div class="min-h-screen bg-surface tech-grid-bg flex items-center justify-center px-4">
  <!-- Glow -->
  <div class="fixed inset-0 pointer-events-none"
       style="background: radial-gradient(ellipse 60% 50% at 50% 30%, hsl(174 100% 44% / 0.05) 0%, transparent 70%);"></div>

  <div class="relative w-full max-w-sm">
    <!-- Panel header -->
    <div class="bg-surface-elevated border border-border border-b-0 px-6 py-4 flex items-center gap-3">
      <div class="flex gap-1.5">
        <div class="w-2.5 h-2.5 rounded-full bg-border"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-border"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-primary/60"></div>
      </div>
      <span class="font-mono text-xs text-muted tracking-widest">认证 :: 登录</span>
    </div>

    <!-- Panel body -->
    <div class="bg-surface-elevated border border-border px-8 py-10">

      <!-- Logo & title -->
      <div class="flex flex-col items-center mb-8">
        <div class="w-10 h-10 border border-primary flex items-center justify-center mb-4">
          <div class="w-4 h-4 bg-primary"></div>
        </div>
        <div class="sys-label mb-1">// 身份验证</div>
        <h1 class="font-mono text-xl font-bold text-primary">微信扫码登录</h1>
        <p class="text-xs font-mono text-muted mt-2 text-center">使用微信扫描下方二维码，安全快捷登录</p>
      </div>

      <% if @privacy_iframe_mode %>
        <div class="alert alert-danger mb-6 font-mono text-xs">
          检测到隐私模式。登录可能无法正常工作。请在新窗口中打开。
        </div>
      <% end %>

      <!-- WeChat QR Login -->
      <div data-controller="wechat-login"
           class="flex flex-col items-center gap-4">

        <!-- QR code -->
        <div class="relative w-44 h-44 border border-border bg-surface flex items-center justify-center">
          <div data-wechat-login-target="loadingSpinner"
               class="absolute inset-0 flex items-center justify-center">
            <div class="w-6 h-6 border-2 border-primary/30 border-t-primary rounded-full animate-spin"></div>
          </div>
          <img data-wechat-login-target="qrImage"
               src=""
               alt="微信登录二维码"
               class="hidden w-full h-full object-contain" />
        </div>

        <!-- Status & countdown -->
        <p data-wechat-login-target="status"
           class="font-mono text-xs text-muted text-center">正在生成二维码…</p>

        <p class="font-mono text-xs text-muted/60">
          二维码有效期：<span data-wechat-login-target="countdown" class="text-primary">60s</span>
        </p>

        <!-- Refresh button -->
        <button data-wechat-login-target="refreshBtn"
                data-action="click->wechat-login#refresh"
                class="hidden btn-ghost btn-sm font-mono text-xs tracking-wider">
          刷新二维码
        </button>

        <!-- Tips -->
        <div class="w-full border-t border-border pt-4 mt-2 space-y-2">
          <div class="flex items-start gap-2 text-xs font-mono text-muted/70">
            <span class="text-primary shrink-0">01</span>
            <span>打开手机微信，点击右上角「+」</span>
          </div>
          <div class="flex items-start gap-2 text-xs font-mono text-muted/70">
            <span class="text-primary shrink-0">02</span>
            <span>选择「扫一扫」扫描上方二维码</span>
          </div>
          <div class="flex items-start gap-2 text-xs font-mono text-muted/70">
            <span class="text-primary shrink-0">03</span>
            <span>在微信中确认登录，即可自动跳转</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="px-8 py-4 border border-border border-t-0 bg-surface text-center">
      <p class="text-xs font-mono text-muted/50">
        登录即表示您同意我们的服务条款与隐私政策
      </p>
    </div>

    <% if Rails.env.development? %>
    <!-- DEV ONLY: Mock login shortcut -->
    <div class="mt-4 border border-yellow-500/30 bg-yellow-500/5 p-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-yellow-400 font-mono text-xs tracking-widest uppercase">⚠ Dev Only</span>
        <span class="text-xs font-mono text-muted/60">· 仅开发环境可见</span>
      </div>
      <%= button_to dev_mock_login_path, method: :post,
            class: "w-full btn-sm font-mono text-xs tracking-wider border border-yellow-500/50 text-yellow-400 hover:bg-yellow-500/10 transition-colors py-2",
            data: { turbo: false } do %>
        快速模拟登录（自动创建 Dev 账号）
      <% end %>
      <div class="mt-2 text-center">
        <%= link_to "选择已有用户登录 →", dev_mock_login_path,
              class: "text-xs font-mono text-yellow-400/60 hover:text-yellow-400 transition-colors" %>
      </div>
    </div>
    <% end %>
  </div>
</div>
