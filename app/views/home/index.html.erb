<%# TECH AGENT HOME — Dark minimal, mission-control aesthetic %>

<!-- HERO: Command Center -->
<section class="relative min-h-screen flex items-center overflow-hidden bg-surface tech-grid-bg">
  <!-- Radial glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-1/3 w-96 h-96 rounded-full opacity-10"
         style="background: radial-gradient(circle, hsl(174 100% 44%) 0%, transparent 70%);"></div>
  </div>

  <div class="relative z-10 container-xl mx-auto px-6 py-24 text-center">
    <!-- 主标题 -->
    <div class="mb-12">
      <h1 class="font-mono text-4xl md:text-6xl font-bold leading-tight tracking-tight">
        <span class="text-secondary">律师 AI 助手，</span><span class="text-primary">就用青狮龙虾</span>
      </h1>
    </div>

    <!-- 副标题 -->
    <div class="mb-12">
      <p class="font-mono text-xl md:text-3xl font-bold leading-none tracking-tight">
        <span class="text-secondary">让每一位律师拥有 </span><span style="color: hsl(174, 100%, 44%)">7x24 AI 助手</span><span class="accent-line"></span>
      </p>
    </div>

    <!-- CTA 按钮 -->
    <div class="flex items-center justify-center gap-4 flex-wrap">
      <%= link_to "#video-resources", class: "btn-outline btn-md font-mono text-sm tracking-widest inline-flex items-center gap-2" do %>
        <%= lucide_icon "rocket", class: "w-4 h-4" %>
        <span>立即安装部署</span>
      <% end %>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-xs font-mono text-muted tracking-widest">向下滚动</span>
    <%= lucide_icon "chevron-down", class: "w-4 h-4 text-primary" %>
  </div>
</section>

<!-- SECTION: Pricing Table -->
<section id="pricing" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">

    <div class="mb-12 text-center">
      <div class="sys-label mb-3 justify-center flex">// 服务方案</div>
      <h2 class="font-mono text-3xl md:text-4xl font-bold text-primary tracking-tight mb-3">选择适合你的方案</h2>
      <p class="text-secondary text-base max-w-xl mx-auto">线上交付 · 线下面对面 · 团购立减——总有一款适合你</p>
    </div>

    <!-- 定价对比表 -->
    <div class="overflow-x-auto">
      <table class="w-full font-mono text-sm border-separate border-spacing-0">
        <thead>
          <tr>
            <th class="text-left py-5 pr-6 text-muted font-normal tracking-widest text-xs uppercase w-1/4 border-b border-border"></th>

            <!-- 方案一 -->
            <th class="text-center py-5 px-6 border-b border-border w-[25%]">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案一</div>
              <div class="text-xs text-muted/60 mb-3">1 人 · 1 年期 · 线上交付</div>
              <div class="text-3xl font-bold text-primary">1999<span class="text-sm font-normal text-muted ml-1">元</span></div>
            </th>

            <!-- 方案二（推荐） -->
            <th class="text-center py-5 px-6 border-b w-[25%]" style="border-color: hsl(174,100%,44%); background: hsl(174,100%,44%,0.04);">
              <div class="inline-block text-xs font-bold tracking-widest px-3 py-0.5 mb-2" style="background: hsl(174,100%,44%); color: #0a0f0d;">★ 最受欢迎</div>
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案二</div>
              <div class="text-xs text-muted/60 mb-3">1 人 · 1 年期 · 线下交付</div>
              <div class="text-3xl font-bold" style="color: hsl(174,100%,44%)">2999<span class="text-sm font-normal text-muted ml-1">元</span></div>
            </th>

            <!-- 方案三 -->
            <th class="text-center py-5 px-6 border-b border-border w-[25%]">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案三</div>
              <div class="text-xs text-muted/60 mb-3">2 人 · 1 年期 · 线下团购</div>
              <div class="text-3xl font-bold text-primary">3998<span class="text-sm font-normal text-muted ml-1">元</span></div>
              <div class="text-xs mt-1" style="color: hsl(174,100%,44%)">每人立减 1000 元</div>
            </th>
          </tr>
        </thead>

        <tbody>
          <%
            rows = [
              # [行标签,        方案一值,              方案二值,              方案三值,       是否分组标题]
              ["服务形式",      "线上课 + 青狮龙虾",   "线上课 + 线下课 + 龙虾", "线上课 + 线下课 + 龙虾", false],
              ["领养龙虾数量",  "1 只",                "1 只",                "2 只",          false],
              ["人数",          "1 人",                "1 人",                "2 人",          false],
              ["龙虾使用期限",  "1 年",                "1 年",                "1 年",          false],
              ["线上全套视频",  "✅",                  "✅",                  "✅",             false],
              ["线上会议答疑",  "> 12 次",             "> 12 次",              "> 12 次",       false],
              ["远程协助",      "✅",                  "✅",                  "✅",             false],
              ["线下面对面交付","—",                   "✅",                  "✅",             false],
              # 分组标题
              ["// 交付技能",   "",                    "",                    "",              true],
              ["安装部署青狮龙虾",       "✅", "✅", "✅", false],
              ["案件数据脱敏",           "✅", "✅", "✅", false],
              ["配置企业微信、飞书",     "✅", "✅", "✅", false],
              ["AI 合同审核 Word 版",    "✅", "✅", "✅", false],
              ["AI 文书撰写 Word 版",    "✅", "✅", "✅", false],
              ["AI 制作 PPT",            "✅", "✅", "✅", false],
              ["AI 配图",                "✅", "✅", "✅", false],
              ["AI 公众号写作",          "✅", "✅", "✅", false],
              ["AI 公众号排版/发文",     "✅", "✅", "✅", false],
              ["AI 写书",                "✅", "✅", "✅", false],
              ["AI 搭建本地知识库",      "✅", "✅", "✅", false],
              ["AI 阅卷",                "✅", "✅", "✅", false],
              ["AI 诉讼可视化",          "✅", "✅", "✅", false],
              ["AI 视频剪辑",            "✅", "✅", "✅", false],
              ["AI 创作你自己的 Skill",  "✅", "✅", "✅", false],
              ["更多技能上线中…",        "✅", "✅", "✅", false],
            ]
          %>
          <% rows.each_with_index do |(label, v1, v2, v3, is_group), i| %>
            <% if is_group %>
              <tr>
                <td colspan="4" class="pt-6 pb-2 text-xs text-muted tracking-widest uppercase border-b border-border/30">
                  <%= label %>
                </td>
              </tr>
            <% else %>
              <tr class="<%= i.even? ? 'bg-surface-elevated/20' : '' %>">
                <td class="py-3 pr-6 text-sm font-mono font-medium text-primary border-b border-border/30"><%= label %></td>
                <td class="py-3 px-6 text-center text-sm border-b border-border/30 text-secondary"><%= raw v1.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
                <td class="py-3 px-6 text-center text-sm border-b border-border/30 font-semibold" style="background: hsl(174,100%,44%,0.04);"><%= raw v2.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
                <td class="py-3 px-6 text-center text-sm border-b border-border/30 text-secondary"><%= raw v3.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
              </tr>
            <% end %>
          <% end %>

          <!-- 购买按钮行 -->
          <tr>
            <td class="pt-6 pb-2"></td>
            <td class="pt-6 pb-2 px-6 text-center">
              <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </td>
            <td class="pt-6 pb-2 px-6 text-center" style="background: hsl(174,100%,44%,0.04);">
              <%= link_to wechat_qrcode_path, class: "btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center", style: "background: hsl(174,100%,44%); color: #0a0f0d; font-weight: 700;" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </td>
            <td class="pt-6 pb-2 px-6 text-center">
              <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- 底部补充说明 -->
    <p class="text-center text-xs font-mono text-muted/60 mt-8">
      购买即微信登录 → 扫码联系创始人确认方案 · 支持发票
    </p>

  </div>
</section>

<!-- SECTION: 3 Reasons -->
<section id="reasons" class="py-20 bg-surface-elevated border-t border-border">
  <div class="container-xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12">
      <h2 class="section-title !mb-0">3 点使用<span style="color: hsl(174, 100%, 44%)">青狮龙虾</span>的理由</h2>
      <p class="section-subtitle mt-2">效果好、更安全、还便宜——专为律师而生</p>
    </div>

    <!-- Reasons Grid -->
    <% skill_count = Skill.count %>
    <div class="grid md:grid-cols-3 gap-6" style="grid-template-rows: auto;">

      <!-- 理由一 -->
      <div class="px-8 py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-10" style="font-size: 7rem; color: hsl(174, 100%, 44%)">
          <%= skill_count %>
        </div>
        <h3 class="font-mono text-lg font-bold text-primary pb-5 tracking-tight">效果好｜<%= skill_count %> 个律师工作场景，量身定制 Skill</h3>
        <p class="text-secondary text-sm leading-loose">
          每一个 Skill 均由律师参与设计，深度覆盖办案、阅卷、咨询、合同审核、庭审笔录、日志记录等全执业场景。不是通用 AI 套壳，是真正懂律师业务的专属助手。
        </p>
      </div>

      <!-- 理由二 -->
      <div class="px-8 py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-10" style="font-size: 7rem; color: hsl(174, 100%, 44%)">
          100%
        </div>
        <h3 class="font-mono text-lg font-bold text-primary pb-5 tracking-tight">更安全｜核心代码 100% 自研、可控</h3>
        <p class="text-secondary text-sm leading-loose">
          全套核心代码独立研发，不依赖任何第三方框架。您的每一份案件资料、每一次对话记录，均在自主可控的系统内流转，零第三方数据中转。
        </p>
      </div>

      <!-- 理由三 -->
      <div class="px-8 py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-10" style="font-size: 7rem; color: hsl(174, 100%, 44%)">
          40%
        </div>
        <h3 class="font-mono text-lg font-bold text-primary pb-5 tracking-tight">还便宜｜独有技术，直降 40% Token 成本</h3>
        <p class="text-secondary text-sm leading-loose">
          独有上下文记忆压缩技术，在保证对话记忆连贯性的前提下，平均节约约 40% 的 Token 使用成本。用得越多，省得越多。
        </p>
      </div>

    </div>
  </div>
</section>

<!-- SECTION: Comparison Table -->
<section id="comparison" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto">
    <div class="mb-12">
      <h2 class="section-title !mb-0"><span style="color: hsl(174, 100%, 44%)">青狮龙虾</span> vs 竞品对比</h2>
      <p class="section-subtitle mt-2">为什么专业律师选择青狮龙虾，而不是 OpenClaw 或 Claude Code</p>
    </div>

    <div class="overflow-x-auto">
              <table class="w-full font-mono text-sm border-separate border-spacing-0">
        <!-- Header -->
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-4 pr-8 text-muted font-normal tracking-widest text-xs uppercase w-1/3"></th>
            <th class="text-center py-4 px-6 text-secondary font-bold text-base w-[22%]">OpenClaw</th>
            <th class="text-center py-4 px-6 text-secondary font-bold text-base w-[22%]">Claude Code</th>
            <th class="text-center py-4 px-6 font-bold text-base w-[22%]" style="color: hsl(174, 100%, 44%)">
              青狮龙虾
              <div class="text-xs font-normal tracking-widest mt-1" style="color: hsl(174, 100%, 44% / 0.7)">推荐</div>
            </th>
          </tr>
        </thead>

        <tbody>
          <% [
            ["目标用户",         "大众人群",           "专业开发者",      "律师 / 法律从业者"],
            ["专为律师设计",     "❌",                 "❌",              "✅ 全场景覆盖"],
            ["全栈集成",         "⚠️ 功能割裂",        "❌ 需自行搭建",   "✅ 统一全栈"],
            ["生产环境就绪",     "⚠️ 依赖第三方",      "❌ 手动配置",     "✅ 开箱即用"],
            ["一键部署",         "⚠️ 平台锁定",        "❌",              "✅ 随处部署"],
            ["开发/生产隔离",    "❌",                 "❌",              "✅ 自动隔离"],
            ["自动备份",         "❌",                 "❌",              "✅ 内置免费"],
            ["AI 成本控制",      "❌ 按 Token 付费",  "❌ 按 Token 付费", "✅ 智能压缩节省 40%"],
            ["数据主权",         "❌ 平台托管",        "✅",              "✅ 完全自有"],
            ["使用界面",         "Web UI",            "终端",            "Web UI + 终端"],
          ].each_with_index do |(label, openclaw, claude, qingclaw), i| %>
            <tr class="border-b border-border/50 <%= i.even? ? 'bg-surface-elevated/30' : '' %>">
              <td class="py-4 pr-8 text-muted tracking-wide text-xs uppercase"><%= label %></td>
              <td class="py-4 px-6 text-center text-secondary"><%= openclaw %></td>
              <td class="py-4 px-6 text-center text-secondary"><%= claude %></td>
              <td class="py-4 px-6 text-center font-semibold" style="color: hsl(174, 100%, 44%)"><%= qingclaw %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- SECTION: Video Resources -->
<section id="video-resources" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">
    <!-- Section Header -->
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="section-title !mb-0">精选视频资源</h2>
        <p class="section-subtitle mt-2">实战性的龙虾技能使用视频，掌握核心技能</p>
      </div>
      <%= link_to video_resources_path, class: "hidden md:flex items-center gap-2 text-xs font-mono text-primary hover:text-primary-light tracking-wider" do %>
        <span>查看全部</span>
        <%= lucide_icon "arrow-right", class: "w-3 h-3" %>
      <% end %>
    </div>

    <!-- Category Filter -->
    <% video_categories = Category.for_video.order(:name) %>
    <% if video_categories.any? %>
    <div class="flex flex-wrap gap-2 mb-10">
      <%= link_to video_resources_path, class: "category-pill active" do %>全部<% end %>
      <% video_categories.each do |category| %>
        <%= link_to video_resources_path(category: category.slug), class: "category-pill" do %>
          <%= category.name %>
        <% end %>
      <% end %>
    </div>
    <% end %>

    <!-- Video Grid -->
    <% videos = VideoResource.includes(:category).order(created_at: :desc).limit(3) %>
    <% if videos.any? %>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
      <% videos.each do |video| %>
      <div class="video-card bg-surface-elevated">
        <div class="video-thumbnail">
          <img src="<%= video.cover_image_url %>"
               alt="<%= video.title %>"
               class="w-full h-full object-cover"
               referrerpolicy="no-referrer"
               onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1505664194779-8beaceb93744?w=600&h=340&fit=crop&q=80';">
          <%= link_to video_resource_path(video),
                class: "absolute inset-0 flex items-center justify-center hover:bg-primary/5 transition-colors" do %>
            <div class="w-12 h-12 border border-primary flex items-center justify-center bg-surface/80 hover:bg-primary/20 transition-colors cursor-pointer">
              <%= lucide_icon "play", class: "w-5 h-5 text-primary ml-0.5" %>
            </div>
          <% end %>
          <% if video.duration.present? %>
          <div class="absolute top-3 right-3 px-2 py-0.5 bg-surface/90 border border-border text-xs font-mono text-muted">
            <%= video.duration %>
          </div>
          <% end %>
          <div class="absolute bottom-0 left-0 right-0 h-px bg-primary/40"></div>
        </div>
        <div class="p-5">
          <div class="sys-label mb-2"><%= video.category.name.upcase %></div>
          <%= link_to video_resource_path(video), class: "block group" do %>
            <h3 class="font-sans text-base font-semibold text-primary mb-2 group-hover:text-primary-light transition-colors"><%= video.title %></h3>
          <% end %>
          <div class="flex items-center justify-between text-xs font-mono text-muted border-t border-border pt-3">
            <span><%= lucide_icon "folder", class: "w-3 h-3 inline" %> <%= video.category.name %></span>
            <span><%= lucide_icon "eye", class: "w-3 h-3 inline" %> <%= number_with_delimiter(video.views_count) %></span>
          </div>
        </div>
      </div>
      <% end %>
    </div>

    <div class="mt-8 text-center">
      <%= link_to video_resources_path, class: "btn-outline btn-md inline-flex items-center gap-2 font-mono text-xs tracking-widest" do %>
        <span>加载更多视频</span>
        <%= lucide_icon "arrow-right", class: "w-3 h-3" %>
      <% end %>
    </div>
    <% end %>
  </div>
</section>

<!-- SECTION: Skills Market -->
<section id="skills-market" class="py-20 bg-surface-elevated border-t border-border">
  <div class="container-xl mx-auto">
    <!-- Section Header -->
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="section-title !mb-0">青狮龙虾 Skill 市场</h2>
        <p class="section-subtitle mt-2">
          专业律师上传的实用技能包 — 文档模板 · AI提示词 · 办案指南
        </p>
      </div>
      <%= link_to skills_path, class: "hidden md:flex items-center gap-2 text-xs font-mono text-primary hover:text-primary-light tracking-wider" do %>
        <span>查看全部</span>
        <%= lucide_icon "arrow-right", class: "w-3 h-3" %>
      <% end %>
    </div>

    <!-- Category Filter（来自数据库） -->
    <div class="flex flex-wrap gap-2 mb-10">
      <%= link_to skills_path, class: "category-pill #{'active' if params[:category].blank?}" do %>全部<% end %>
      <% @skill_categories.each do |cat| %>
        <%= link_to skills_path(category: cat.slug), class: "category-pill #{'active' if params[:category] == cat.slug}" do %>
          <%= cat.name %>
        <% end %>
      <% end %>
    </div>

    <!-- Skills Grid（来自数据库） -->
    <% if @featured_skills.any? %>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
        <% @featured_skills.each do |skill| %>
          <div class="skill-card p-5">
            <div class="flex items-start justify-between mb-4">
              <span class="skill-card-badge"><%= skill.category&.name || "通用" %></span>
              <div class="flex items-center gap-1 text-xs font-mono text-primary">
                <span>★</span>
                <span><%= skill.rating %></span>
              </div>
            </div>

            <h3 class="font-sans text-base font-semibold text-primary mb-2"><%= skill.title %></h3>
            <p class="text-secondary text-sm mb-5 leading-relaxed line-clamp-2"><%= skill.description %></p>

            <div class="flex items-center gap-4 mb-4 text-xs font-mono text-muted">
              <span><%= lucide_icon "file-text", class: "w-3 h-3 inline mr-1" %><%= skill.template_count %> 模板</span>
              <span><%= lucide_icon "download", class: "w-3 h-3 inline mr-1" %><%= number_with_delimiter(skill.download_count) %> 下载</span>
            </div>

            <div class="flex items-center justify-between pt-4 border-t border-border">
              <span class="text-xs font-mono text-muted">BY <%= skill.author_name %></span>
              <%= link_to skill_path(skill), class: "btn-primary btn-xs font-mono text-xs tracking-wider" do %>获取<% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 text-secondary font-mono text-sm">
        暂无技能，敬请期待...
      </div>
    <% end %>

    <div class="mt-8 text-center">
      <%= link_to skills_path, class: "btn-outline btn-md inline-flex items-center gap-2 font-mono text-xs tracking-widest" do %>
        <span>浏览所有技能</span>
        <%= lucide_icon "arrow-right", class: "w-3 h-3" %>
      <% end %>
    </div>
  </div>
</section>

<!-- SECTION: Community -->
<section id="community" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">

    <!-- Section Header -->
    <div class="mb-14">
      <h2 class="section-title !mb-0">199 元加入青狮龙虾社群</h2>
      <p class="section-subtitle mt-2">按大区组建，为了让你们真的能见面</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: 大区 + 理念 -->
      <div>

        <!-- 7大区 -->
        <div class="mb-8">
          <div class="mb-4"></div>
          <div class="grid grid-cols-2 gap-2">
            <% [
              ["华北群", "北京 · 天津 · 石家庄 · 太原 · 呼和浩特 · 济南"],
              ["东北群", "沈阳 · 长春 · 哈尔滨"],
              ["长三角", "上海 · 南京 · 杭州 · 合肥"],
              ["华中群", "郑州 · 武汉 · 长沙 · 南昌"],
              ["华南群", "广州 · 深圳 · 福州 · 南宁 · 海口"],
              ["西南群", "重庆 · 成都 · 贵阳 · 昆明 · 拉萨"],
              ["西北群", "西安 · 兰州 · 西宁 · 银川 · 乌鲁木齐"],
            ].each do |region, cities| %>
              <div class="bg-surface-elevated border border-border hover:border-primary/40 transition-colors p-3">
                <div class="text-primary text-xs font-mono font-bold tracking-widest mb-1"><%= region %></div>
                <div class="text-muted text-xs font-sans"><%= cities %></div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- 创始人的话 -->
        <div class="border-l-2 border-primary pl-5 space-y-4">
          <p class="text-secondary text-base leading-relaxed">
            7 个群，按大区分，<span class="text-primary font-semibold">就近入群</span>。
          </p>
          <p class="text-secondary text-base leading-relaxed">
            每个区，主要城市之间<span class="text-primary font-semibold">高铁两小时</span>都能到。
          </p>
          <p class="text-secondary text-base leading-relaxed">
            法律这行靠信任——坐下来面对面聊 OpenClaw，比什么都强。
          </p>
        </div>

      </div>

      <!-- Right: 二维码 + 入群流程 -->
      <div class="bg-surface-elevated border border-border p-8 flex flex-col items-center">

        <!-- QR Code -->
        <div class="relative w-52 h-52 bg-surface border border-primary/20 p-3 group hover:border-primary/40 transition-all duration-300 mb-6">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <%= image_tag "qingshiying-qrcode.png",
              alt: "青狮龙虾社群二维码",
              class: "relative z-10 w-full h-full object-contain" %>
        </div>

        <p class="text-xs font-mono text-muted tracking-widest mb-8">微信扫码 · 按大区入群</p>

        <!-- 入群流程 -->
        <div class="w-full space-y-3">
          <div class="text-xs font-mono text-muted tracking-widest uppercase mb-3">// 入群流程</div>
          <% [
            ["01", "扫码添加创始人微信"],
            ["02", "告知所在省会城市"],
            ["03", "被拉入对应大区群"],
            ["04", "线上社群答疑+线下碰头"],
          ].each do |step, desc| %>
            <div class="flex items-center gap-4 py-2 border-b border-border last:border-0">
              <span class="font-mono text-xs text-primary w-6 flex-shrink-0"><%= step %></span>
              <span class="text-sm text-secondary"><%= desc %></span>
            </div>
          <% end %>
        </div>

      </div>
    </div>
  </div>
</section>

