<%# TECH AGENT HOME — Dark minimal, mission-control aesthetic %>

<!-- HERO: Command Center -->
<section class="relative min-h-screen flex items-center overflow-hidden bg-surface tech-grid-bg">
  <!-- Radial glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-1/3 w-96 h-96 rounded-full opacity-10"
         style="background: radial-gradient(circle, hsl(174 100% 44%) 0%, transparent 70%);"></div>
  </div>

  <div class="relative z-10 container-xl mx-auto px-6 py-24 text-center">
    <!-- 主标题 -->
    <div class="mb-12">
      <h1 class="font-mono text-4xl md:text-6xl font-bold leading-tight tracking-tight">
        <span class="text-secondary">律师 AI 助手，</span><span class="text-primary">就用青狮龙虾</span>
      </h1>
    </div>

    <!-- 副标题 -->
    <div class="mb-12">
      <p class="font-mono text-xl md:text-3xl font-bold leading-none tracking-tight">
        <span class="text-secondary">让每一位律师拥有 </span><span style="color: hsl(174, 100%, 44%)">7x24 AI 助手</span><span class="accent-line"></span>
      </p>
    </div>

    <!-- CTA 按钮 -->
    <div class="flex items-center justify-center gap-4 flex-wrap">
      <%= link_to "#video-resources", class: "btn-outline btn-md font-mono text-sm tracking-widest inline-flex items-center gap-2" do %>
        <%= lucide_icon "rocket", class: "w-4 h-4" %>
        <span>立即安装部署</span>
      <% end %>
      <% if @hero_video_url.present? %>
        <button
          onclick="document.getElementById('hero-video-modal').classList.remove('hidden');document.getElementById('hero-video-player').play()"
          class="btn-md font-mono text-sm tracking-widest inline-flex items-center gap-2"
          style="background: hsl(174,100%,44%); color: #0a0f0d; font-weight: 700;">
          <%= lucide_icon "play-circle", class: "w-4 h-4" %>
          <span>观看演示</span>
        </button>
      <% end %>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-xs font-mono text-muted tracking-widest">向下滚动</span>
    <%= lucide_icon "chevron-down", class: "w-4 h-4 text-primary" %>
  </div>
</section>

<% if @hero_video_url.present? %>
<!-- 首页引导视频 Modal -->
<div id="hero-video-modal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
     style="background: rgba(0,0,0,0.85);"
     onclick="if(event.target===this){closeHeroVideo()}">
  <div class="relative w-full max-w-4xl">
    <!-- 标题 + 关闭按钮 -->
    <div class="flex items-center justify-between mb-3">
      <span class="font-mono text-sm tracking-widest" style="color: hsl(174,100%,44%)"><%= @hero_video_title %></span>
      <button onclick="closeHeroVideo()" class="text-muted hover:text-primary">
        <%= lucide_icon "x", class: "w-5 h-5" %>
      </button>
    </div>
    <!-- 视频播放器 -->
    <div class="relative w-full" style="aspect-ratio: 16/9; background: #000; border-radius: 8px; overflow: hidden;">
      <video
        id="hero-video-player"
        src="<%= @hero_video_url %>"
        controls
        class="w-full h-full object-contain"
        style="display: block;">
      </video>
    </div>
  </div>
</div>

<script>
  function closeHeroVideo() {
    var modal = document.getElementById('hero-video-modal');
    var player = document.getElementById('hero-video-player');
    modal.classList.add('hidden');
    player.pause();
    player.currentTime = 0;
  }
  // ESC 键关闭
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeHeroVideo();
  });
</script>
<% end %>

<!-- SECTION: Pricing Table -->
<section id="pricing" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">

    <div class="mb-12 text-center">
      <h2 class="font-mono text-3xl md:text-4xl font-bold text-primary tracking-tight mb-3">选择适合你的方案</h2>
      <p class="text-secondary text-base max-w-xl mx-auto">线上交付 · 线下面对面 · 团购立减——总有一款适合你</p>
    </div>

    <!-- 定价对比表 -->
    <!-- 定价对比表 -->
    <div class="relative overflow-x-auto pt-6">

      <table class="w-full font-mono text-sm border-separate border-spacing-0">
        <thead>
          <tr>
            <th class="text-left py-5 pr-6 text-muted font-normal tracking-widest text-xs uppercase w-1/5 border-b border-border"></th>

            <!-- 方案一 -->
            <th class="text-center py-5 px-4 border-b border-border w-[20%]">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案一</div>
              <div class="text-sm text-muted/60 mb-4">1 年期使用权</div>
              <div class="text-sm text-muted line-through font-mono mb-1">原价 1999 元</div>
              <div class="text-3xl font-bold text-primary mb-4">999<span class="text-sm font-normal text-muted ml-1">元</span></div>
              <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </th>

            <!-- 方案二 -->
            <th class="text-center py-5 px-4 border-b border-border w-[20%]">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案二</div>
              <div class="text-sm text-muted/60 mb-4">线上课（含 1 年期使用权）</div>
              <div class="text-sm mb-1 invisible" aria-hidden="true">&nbsp;</div>
              <div class="text-3xl font-bold text-primary mb-4">1999<span class="text-sm font-normal text-muted ml-1">元</span></div>
              <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </th>

            <!-- 方案三 -->
            <th class="text-center py-5 px-4 border-b w-[20%]" style="border-color: hsl(174,100%,44%); background: hsl(174,100%,44%,0.04);">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案三</div>
              <div class="text-sm text-muted/60 mb-4">线下课（含 1 年期使用权）</div>
              <div class="text-sm mb-1 invisible" aria-hidden="true">&nbsp;</div>
              <div class="text-3xl font-bold mb-4" style="color: hsl(174,100%,44%)">2999<span class="text-sm font-normal text-muted ml-1">元</span></div>
              <%= link_to wechat_qrcode_path, class: "btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center", style: "background: hsl(174,100%,44%); color: #0a0f0d; font-weight: 700;" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </th>

            <!-- 方案四 -->
            <th class="text-center py-5 px-4 border-b border-border w-[20%]">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案四</div>
              <div class="text-sm text-muted/60 mb-4">律所/律师团队内训</div>
              <div class="text-sm text-muted line-through font-mono mb-1">原价 45000 元</div>
              <div class="text-3xl font-bold text-primary mb-4">30000<span class="text-sm font-normal text-muted ml-1">元/天</span></div>
              <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </th>
          </tr>
        </thead>

        <tbody>
          <%
            rows = [
              # [行标签,        方案一值,         方案二值,              方案三值,              方案四值,          是否分组标题]
              ["服务形式",      "龙虾软件",        "线上课",              "线上课 + 线下课",     "线上课 + 线下课", false],
              ["领养龙虾数量",  "青狮龙虾 1 只",   "青狮龙虾 1 只",       "青狮龙虾 1 只",       "青狮龙虾 15 只",   false],
              ["人数",          "1 人",            "1 人",                "1 人",                "≤ 15 人",         false],
              ["龙虾使用期限",  "1 年",            "1 年",                "1 年",                "1 年",            false],
              ["线上全套视频",  "—",               "✅",                  "✅",                  "✅",               false],
              ["线上会议答疑",  "—",               "> 12 次/年",          "> 12 次/年",          "> 12 次/年",      false],
              ["远程协助",      "—",               "✅",                  "✅",                  "✅",               false],
              ["线下面对面交付","—",               "—",                   "✅",                  "✅",               false],
            ]
          %>
          <% rows.each_with_index do |(label, v1, v2, v3, v4, is_group), i| %>
            <% if is_group %>
              <tr>
                <td colspan="5" class="pt-8 pb-3 text-base font-bold tracking-widest text-center border-b border-border/30" style="color: hsl(174,100%,44%)">
                  <%= label %>
                </td>
              </tr>

            <% else %>
              <tr class="<%= i.even? ? 'bg-surface-elevated/20' : '' %>">
                <td class="py-3 pr-6 text-sm font-mono font-medium text-primary border-b border-border/30"><%= label %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= raw v1.to_s.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= raw v2.to_s.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 font-semibold" style="background: hsl(174,100%,44%,0.04);"><%= raw v3.to_s.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= raw v4.to_s.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
              </tr>
            <% end %>
          <% end %>


        </tbody>
      </table>
    </div>

    <!-- 底部补充说明 -->
    <p class="text-center text-xs font-mono text-muted/60 mt-8">
      支持发票 · 支持公户付款
    </p>

  </div>
</section>

<!-- SECTION: 交付技能 -->
<section id="delivered-skills" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">

    <!-- Section Header -->
    <div class="mb-10">
      <h2 class="font-mono text-3xl md:text-4xl font-bold text-primary tracking-tight mb-3">交付技能</h2>
      <p class="text-secondary text-base max-w-xl">每一个 Skill 均由律师参与设计，覆盖真实执业场景——交付即可上手，开箱即用</p>
    </div>

    <% if @delivered_skills.any? %>
      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="min-w-full divide-y divide-border">
          <thead>
            <tr class="bg-surface-elevated">
              <th class="px-5 py-3 text-left text-xs font-mono font-medium text-muted uppercase tracking-widest w-16 whitespace-nowrap">序号</th>
              <th class="px-5 py-3 text-left text-xs font-mono font-medium text-muted uppercase tracking-widest whitespace-nowrap">技能名称</th>
              <th class="px-5 py-3 text-left text-xs font-mono font-medium text-muted uppercase tracking-widest whitespace-nowrap">使用场景</th>
              <th class="px-5 py-3 text-left text-xs font-mono font-medium text-muted uppercase tracking-widest whitespace-nowrap">AI 完成度</th>
              <th class="px-5 py-3 text-center text-xs font-mono font-medium text-muted uppercase tracking-widest whitespace-nowrap">演示</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @delivered_skills.each_with_index do |skill, idx| %>
              <tr class="<%= idx.even? ? 'bg-surface' : 'bg-surface-elevated/30' %> hover:bg-primary/5 transition-colors">
                <td class="px-5 py-4 text-sm font-mono font-bold text-muted/60">
                  <%= "%02d" % (idx + 1) %>
                </td>
                <td class="px-5 py-4 text-sm font-semibold text-primary">
                  <%= skill.name %>
                </td>
                <td class="px-5 py-4 text-sm text-secondary max-w-xs">
                  <%= skill.scenario.present? ? skill.scenario : "—" %>
                </td>
                <td class="px-5 py-4">
                  <% if skill.ai_completion.present? %>
                    <div style="display:flex; align-items:center; gap:8px; min-width:120px;">
                      <div style="flex:1; height:6px; background:rgba(128,128,128,0.2); border-radius:9999px; overflow:hidden;">
                        <div style="height:6px; border-radius:9999px; background:hsl(174,100%,44%); width:<%= skill.ai_completion %>%;"></div>
                      </div>
                      <span style="font-size:12px; font-family:monospace; color:hsl(174,100%,44%); min-width:32px; text-align:right;"><%= skill.ai_completion %>%</span>
                    </div>
                  <% else %>
                    <span class="text-muted/40 text-sm">—</span>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-center">
                  <% if skill.demo_video_url.present? %>
                    <%= link_to skill.demo_video_url, target: "_blank", rel: "noopener noreferrer",
                        class: "inline-flex items-center gap-1 text-xs font-mono text-primary hover:text-primary-light transition-colors" do %>
                      <%= lucide_icon "play-circle", class: "w-4 h-4" %>
                      <span class="hidden sm:inline">演示</span>
                    <% end %>
                  <% else %>
                    <span class="text-muted/40 text-xs">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted text-sm font-mono">技能整理中，敬请期待…</p>
    <% end %>

  </div>
</section>

<!-- SECTION: 3 Reasons -->
<section id="reasons" class="py-20 bg-surface-elevated border-t border-border">
  <div class="container-xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12">
      <h2 class="section-title !mb-0">3 点使用<span style="color: hsl(174, 100%, 44%)">青狮龙虾</span>的理由</h2>
      <p class="section-subtitle mt-2">效果好、更安全、还便宜——专为律师而生</p>
    </div>

    <!-- Reasons Grid -->
    <% skill_count = @delivered_skills.count %>
    <div class="grid md:grid-cols-3 gap-6" style="grid-template-rows: auto;">

      <!-- 理由一 -->
      <div class="px-8 py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-10" style="font-size: 7rem; color: hsl(174, 100%, 44%)">
          <%= skill_count %>
        </div>
        <h3 class="font-mono text-lg font-bold text-primary pb-5 tracking-tight">效果好｜<%= skill_count %> 个律师工作场景，量身定制 Skill</h3>
        <p class="text-secondary text-sm leading-loose">
          每一个 Skill 均由律师参与设计，深度覆盖办案、阅卷、咨询、合同审核、庭审笔录、日志记录等全执业场景。不是通用 AI 套壳，是真正懂律师业务的专属助手。
        </p>
      </div>

      <!-- 理由二 -->
      <div class="px-8 py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-10" style="font-size: 7rem; color: hsl(174, 100%, 44%)">
          100%
        </div>
        <h3 class="font-mono text-lg font-bold text-primary pb-5 tracking-tight">更安全｜核心代码 100% 自研、可控</h3>
        <p class="text-secondary text-sm leading-loose">
          全套核心代码独立研发，不依赖任何第三方框架。您的每一份案件资料、每一次对话记录，均在自主可控的系统内流转，零第三方数据中转。
        </p>
      </div>

      <!-- 理由三 -->
      <div class="px-8 py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-10" style="font-size: 7rem; color: hsl(174, 100%, 44%)">
          40%
        </div>
        <h3 class="font-mono text-lg font-bold text-primary pb-5 tracking-tight">还便宜｜独有技术，直降 40% Token 成本</h3>
        <p class="text-secondary text-sm leading-loose">
          独有上下文记忆压缩技术，在保证对话记忆连贯性的前提下，平均节约约 40% 的 Token 使用成本。用得越多，省得越多。
        </p>
      </div>

    </div>
  </div>
</section>


<!-- SECTION: Video Resources -->
<section id="video-resources" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">
    <!-- Section Header -->
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="section-title !mb-0">精选视频资源</h2>
        <p class="section-subtitle mt-2">实战性的龙虾技能使用视频，掌握核心技能</p>
      </div>
      <%= link_to video_resources_path, class: "hidden md:flex items-center gap-2 text-xs font-mono text-primary hover:text-primary-light tracking-wider" do %>
        <span>查看全部</span>
        <%= lucide_icon "arrow-right", class: "w-3 h-3" %>
      <% end %>
    </div>

    <!-- Category Filter -->
    <% video_categories = Category.for_video.order(:name) %>
    <% if video_categories.any? %>
    <div class="flex flex-wrap gap-2 mb-10">
      <%= link_to video_resources_path, class: "category-pill active" do %>全部<% end %>
      <% video_categories.each do |category| %>
        <%= link_to video_resources_path(category: category.slug), class: "category-pill" do %>
          <%= category.name %>
        <% end %>
      <% end %>
    </div>
    <% end %>

    <!-- Video Grid -->
    <% videos = VideoResource.includes(:category).order(created_at: :desc).limit(3) %>
    <% if videos.any? %>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
      <% videos.each do |video| %>
      <div class="video-card bg-surface-elevated">
        <div class="video-thumbnail">
          <img src="<%= video.cover_image_url %>"
               alt="<%= video.title %>"
               class="w-full h-full object-cover"
               referrerpolicy="no-referrer"
               onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1505664194779-8beaceb93744?w=600&h=340&fit=crop&q=80';">
          <%= link_to video_resource_path(video),
                class: "absolute inset-0 flex items-center justify-center hover:bg-primary/5 transition-colors" do %>
            <div class="w-12 h-12 border border-primary flex items-center justify-center bg-surface/80 hover:bg-primary/20 transition-colors cursor-pointer">
              <%= lucide_icon "play", class: "w-5 h-5 text-primary ml-0.5" %>
            </div>
          <% end %>
          <% if video.duration.present? %>
          <div class="absolute top-3 right-3 px-2 py-0.5 bg-surface/90 border border-border text-xs font-mono text-muted">
            <%= video.duration %>
          </div>
          <% end %>
          <div class="absolute bottom-0 left-0 right-0 h-px bg-primary/40"></div>
        </div>
        <div class="p-5">
          <div class="sys-label mb-2"><%= video.category.name.upcase %></div>
          <%= link_to video_resource_path(video), class: "block group" do %>
            <h3 class="font-sans text-base font-semibold text-primary mb-2 group-hover:text-primary-light transition-colors"><%= video.title %></h3>
          <% end %>
          <div class="flex items-center justify-between text-xs font-mono text-muted border-t border-border pt-3">
            <span><%= lucide_icon "folder", class: "w-3 h-3 inline" %> <%= video.category.name %></span>
            <span><%= lucide_icon "eye", class: "w-3 h-3 inline" %> <%= number_with_delimiter(video.views_count) %></span>
          </div>
        </div>
      </div>
      <% end %>
    </div>

    <div class="mt-8 text-center">
      <%= link_to video_resources_path, class: "btn-outline btn-md inline-flex items-center gap-2 font-mono text-xs tracking-widest" do %>
        <span>加载更多视频</span>
        <%= lucide_icon "arrow-right", class: "w-3 h-3" %>
      <% end %>
    </div>
    <% end %>
  </div>
</section>

<%# SECTION: Skills Market — 已隐藏，与「交付技能」板块重叠 %>

<!-- SECTION: Community -->
<section id="community" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">

    <!-- Section Header -->
    <div class="mb-14">
      <h2 class="section-title !mb-0">199 元加入青狮龙虾社群</h2>
      <p class="section-subtitle mt-2">按大区组建，为了让你们真的能见面</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: 大区 + 理念 -->
      <div>

        <!-- 7大区 -->
        <div class="mb-8">
          <div class="mb-4"></div>
          <div class="grid grid-cols-2 gap-2">
            <% [
              ["华北群", "北京 · 天津 · 石家庄 · 太原 · 呼和浩特 · 济南"],
              ["东北群", "沈阳 · 长春 · 哈尔滨"],
              ["长三角", "上海 · 南京 · 杭州 · 合肥"],
              ["华中群", "郑州 · 武汉 · 长沙 · 南昌"],
              ["华南群", "广州 · 深圳 · 福州 · 南宁 · 海口"],
              ["西南群", "重庆 · 成都 · 贵阳 · 昆明 · 拉萨"],
              ["西北群", "西安 · 兰州 · 西宁 · 银川 · 乌鲁木齐"],
            ].each do |region, cities| %>
              <div class="bg-surface-elevated border border-border hover:border-primary/40 transition-colors p-3">
                <div class="text-primary text-xs font-mono font-bold tracking-widest mb-1"><%= region %></div>
                <div class="text-muted text-xs font-sans"><%= cities %></div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- 创始人的话 -->
        <div class="border-l-2 border-primary pl-5 space-y-4">
          <p class="text-secondary text-base leading-relaxed">
            7 个群，按大区分，<span class="text-primary font-semibold">就近入群</span>。
          </p>
          <p class="text-secondary text-base leading-relaxed">
            每个区，主要城市之间<span class="text-primary font-semibold">高铁两小时</span>都能到。
          </p>
          <p class="text-secondary text-base leading-relaxed">
            法律这行靠信任——坐下来面对面聊 OpenClaw，比什么都强。
          </p>
        </div>

      </div>

      <!-- Right: 二维码 + 入群流程 -->
      <div class="bg-surface-elevated border border-border p-8 flex flex-col items-center">

        <!-- QR Code -->
        <div class="relative w-52 h-52 bg-surface border border-primary/20 p-3 group hover:border-primary/40 transition-all duration-300 mb-6">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <%= image_tag "qingshiying-qrcode.png",
              alt: "青狮龙虾社群二维码",
              class: "relative z-10 w-full h-full object-contain" %>
        </div>

        <p class="text-xs font-mono text-muted tracking-widest mb-8">微信扫码 · 按大区入群</p>

        <!-- 入群流程 -->
        <div class="w-full space-y-3">
          <div class="text-xs font-mono text-muted tracking-widest uppercase mb-3">// 入群流程</div>
          <% [
            ["01", "扫码添加创始人微信"],
            ["02", "告知所在省会城市"],
            ["03", "被拉入对应大区群"],
            ["04", "线上社群答疑+线下碰头"],
          ].each do |step, desc| %>
            <div class="flex items-center gap-4 py-2 border-b border-border last:border-0">
              <span class="font-mono text-xs text-primary w-6 flex-shrink-0"><%= step %></span>
              <span class="text-sm text-secondary"><%= desc %></span>
            </div>
          <% end %>
        </div>

      </div>
    </div>
  </div>
</section>

