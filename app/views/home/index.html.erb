<%# TECH AGENT HOME — Dark minimal, mission-control aesthetic %>

<!-- HERO: Command Center -->
<section class="relative min-h-screen flex items-center overflow-hidden bg-surface tech-grid-bg">
  <!-- Radial glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-1/3 w-96 h-96 rounded-full opacity-10"
         style="background: radial-gradient(circle, hsl(174 100% 44%) 0%, transparent 70%);"></div>
  </div>

  <div class="relative z-10 container-xl mx-auto px-4 sm:px-6 py-16 sm:py-24 text-center">
    <!-- 主标题 -->
    <div class="mb-8 sm:mb-12">
      <h1 class="font-mono text-3xl sm:text-4xl md:text-6xl font-bold leading-tight tracking-tight">
        <span class="text-secondary">律师 AI 助手，</span><br class="sm:hidden"><span class="text-primary">就用青狮龙虾</span>
      </h1>
    </div>

    <!-- 副标题 -->
    <div class="mb-8 sm:mb-12">
      <p class="font-mono text-lg sm:text-xl md:text-3xl font-bold leading-snug tracking-tight">
        <span class="text-secondary">让每一位律师拥有 </span><span style="color: hsl(174, 100%, 44%)">7x24 AI 助手</span><span class="accent-line"></span>
      </p>
    </div>

    <!-- CTA 按钮 -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
      <%= link_to "#video-resources", class: "btn-outline btn-md font-mono text-sm tracking-widest inline-flex items-center justify-center gap-2 w-full sm:w-auto" do %>
        <%= lucide_icon "rocket", class: "w-4 h-4" %>
        <span>立即安装部署</span>
      <% end %>
      <% if @hero_video_url.present? %>
        <button
          onclick="document.getElementById('hero-video-modal').classList.remove('hidden');document.getElementById('hero-video-player').play()"
          class="btn-md font-mono text-sm tracking-widest inline-flex items-center justify-center gap-2 w-full sm:w-auto"
          style="background: hsl(174,100%,44%); color: #0a0f0d; font-weight: 700;">
          <%= lucide_icon "play-circle", class: "w-4 h-4" %>
          <span>观看演示</span>
        </button>
      <% end %>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-xs font-mono text-muted tracking-widest">向下滚动</span>
    <%= lucide_icon "chevron-down", class: "w-4 h-4 text-primary" %>
  </div>
</section>

<% if @hero_video_url.present? %>
<!-- 首页引导视频 Modal -->
<div id="hero-video-modal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
     style="background: rgba(0,0,0,0.85);"
     onclick="if(event.target===this){closeHeroVideo()}">
  <div class="relative w-full max-w-4xl">
    <!-- 标题 + 关闭按钮 -->
    <div class="flex items-center justify-between mb-3">
      <span class="font-mono text-sm tracking-widest" style="color: hsl(174,100%,44%)"><%= @hero_video_title %></span>
      <button onclick="closeHeroVideo()" class="text-muted hover:text-primary">
        <%= lucide_icon "x", class: "w-5 h-5" %>
      </button>
    </div>
    <!-- 视频播放器 -->
    <div class="relative w-full" style="aspect-ratio: 16/9; background: #000; border-radius: 8px; overflow: hidden;">
      <video
        id="hero-video-player"
        src="<%= @hero_video_url %>"
        controls
        class="w-full h-full object-contain"
        style="display: block;">
      </video>
    </div>
  </div>
</div>

<script>
  function closeHeroVideo() {
    var modal = document.getElementById('hero-video-modal');
    var player = document.getElementById('hero-video-player');
    modal.classList.add('hidden');
    player.pause();
    player.currentTime = 0;
  }
  // ESC 键关闭
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeHeroVideo();
  });
</script>
<% end %>

<!-- SECTION: Pricing Table -->
<section id="pricing" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">

    <div class="mb-12 text-center">
      <h2 class="font-mono text-3xl md:text-4xl font-bold text-primary tracking-tight mb-3">选择适合你的方案</h2>
      <p class="text-secondary text-base max-w-xl mx-auto">线上交付 · 线下面对面 · 团购立减——总有一款适合你</p>
    </div>

    <!-- ===== 移动端卡片（手机专属，sm以上隐藏）===== -->
