<!-- SECTION: 线下课程班次 -->
<% if @offline_classes.any? %>
<section id="offline-classes" class="py-16 sm:py-20 bg-surface-elevated border-t border-border">
  <div class="container-xl mx-auto px-6">

    <!-- 标题 -->
    <div class="mb-10">
