<!-- stimulus-validator: allow-script -->
<script>
  var plan3Count = 1;
  var plan3BasePrice = 2999;
  var plan3Discount = 300;
  var plan3MaxCount = 3;

  function updatePlan3(delta) {
    var countEl      = document.getElementById('plan3-count');
    var totalEl      = document.getElementById('plan3-total');
    var minusEl      = document.getElementById('plan3-minus');
    var plusEl       = document.getElementById('plan3-plus');
    var tipEl        = document.getElementById('plan3-tip');
    var originPriceEl   = document.getElementById('plan3-origin-price');
    var lobsterCountEl  = document.getElementById('plan3-lobster-count');
    var grandTotalEl = document.getElementById('plan3-grand-total');
    // 移动端镜像元素
    var mCountEl       = document.getElementById('m-plan3-count');
    var mTotalEl       = document.getElementById('m-plan3-total');
    var mTipEl         = document.getElementById('m-plan3-tip');
    var mOriginEl      = document.getElementById('m-plan3-origin-price');
    var mLobsterEl     = document.getElementById('m-plan3-lobster-count');
    var mGrandTotalEl  = document.getElementById('m-plan3-grand-total');

    plan3Count = Math.max(1, Math.min(plan3MaxCount, plan3Count + delta));
    var unitPrice  = plan3BasePrice - (plan3Count - 1) * plan3Discount;
    var totalSaved = (plan3Count - 1) * plan3Discount * plan3Count;
    var perSave    = (plan3Count - 1) * plan3Discount;

    // 桌面更新
    if (countEl) countEl.textContent = plan3Count;
    // 同步所有 plan3 quantity hidden field（页面可能有多个购买按钮）
    document.querySelectorAll('#plan3-quantity-input').forEach(function(el) { el.value = plan3Count; });
    if (totalEl) totalEl.textContent = unitPrice.toLocaleString();
    if (lobsterCountEl) lobsterCountEl.textContent = '青狮龙虾 ' + plan3Count + ' 只';

    function applyOrigin(el) {
      if (!el) return;
      if (plan3Count === 1) { el.classList.add('invisible'); el.textContent = '\u00a0'; }
      else { el.classList.remove('invisible'); el.textContent = '原价 2999 元'; }
    }
    applyOrigin(originPriceEl);
    applyOrigin(mOriginEl);

    function applyGrandTotal(el) {
      if (!el) return;
      if (plan3Count === 1) { el.classList.add('invisible'); el.textContent = '\u00a0'; }
      else { el.classList.remove('invisible'); el.textContent = '共计 ' + (unitPrice * plan3Count).toLocaleString() + ' 元'; }
    }
    applyGrandTotal(grandTotalEl);
    applyGrandTotal(mGrandTotalEl);

    var tipHtml = plan3Count === 1
      ? '点击 +<br>享受团购价'
      : '每人立减 ' + perSave + ' 元<br>共减 ' + totalSaved + ' 元';
    if (tipEl) tipEl.innerHTML = tipHtml;
    if (mTipEl) mTipEl.innerHTML = tipHtml;

    // 移动端计数/价格
    if (mCountEl) mCountEl.textContent = plan3Count;
    if (mTotalEl) mTotalEl.textContent = unitPrice.toLocaleString();
    if (mLobsterEl) mLobsterEl.textContent = plan3Count;

    if (minusEl) {
      minusEl.style.opacity = plan3Count <= 1 ? '0.3' : '1';
      minusEl.style.cursor  = plan3Count <= 1 ? 'not-allowed' : 'pointer';
    }
    if (plusEl) {
      plusEl.style.opacity = plan3Count >= plan3MaxCount ? '0.3' : '1';
      plusEl.style.cursor  = plan3Count >= plan3MaxCount ? 'not-allowed' : 'pointer';
    }
  }

  // 初始化状态
  document.addEventListener('DOMContentLoaded', function() {
    if (document.getElementById('plan3-count')) { updatePlan3(0); }
    if (document.getElementById('plan4-count')) { updatePlan4(0); }
  });

  // 方案四
  var plan4Count    = 15;
  var plan4MinCount = 15;
  var plan4UnitPrice = 1999;

  function updatePlan4(delta) {
    var countEl        = document.getElementById('plan4-count');
    var countDisplayEl = document.getElementById('plan4-count-display');
    var totalEl        = document.getElementById('plan4-total');
    var minusEl        = document.getElementById('plan4-minus');
    var plusEl         = document.getElementById('plan4-plus');
    var tipEl          = document.getElementById('plan4-tip');
    var lobsterEl      = document.getElementById('plan4-lobster-count');
    // 移动端镜像元素
    var mCountEl       = document.getElementById('m-plan4-count');
    var mDisplayEl     = document.getElementById('m-plan4-count-display');
    var mTotalEl       = document.getElementById('m-plan4-total');
    var mTipEl         = document.getElementById('m-plan4-tip');
    var mLobsterEl     = document.getElementById('m-plan4-lobster-count');

    plan4Count = Math.max(plan4MinCount, plan4Count + delta);
    var total = plan4Count * plan4UnitPrice;

    // 桌面
    if (countEl) countEl.textContent = plan4Count;
    if (totalEl) totalEl.textContent = plan4UnitPrice.toLocaleString();
    if (countDisplayEl) countDisplayEl.textContent = total.toLocaleString();
    if (lobsterEl) lobsterEl.textContent = '青狮龙虾 ' + plan4Count + ' 只';

    // 移动端
    if (mCountEl) mCountEl.textContent = plan4Count;
    if (mTotalEl) mTotalEl.textContent = plan4UnitPrice.toLocaleString();
    if (mDisplayEl) mDisplayEl.textContent = total.toLocaleString();
    if (mLobsterEl) mLobsterEl.textContent = plan4Count;

    var tipHtml = plan4Count === plan4MinCount
      ? '最低 15 人起'
      : '每人立减 1000 元<br>共减 ' + ((2999 - plan4UnitPrice) * plan4Count).toLocaleString() + ' 元';
    if (tipEl) tipEl.innerHTML = tipHtml;
    if (mTipEl) mTipEl.innerHTML = tipHtml;

    if (minusEl) {
      minusEl.style.opacity = plan4Count <= plan4MinCount ? '0.3' : '1';
      minusEl.style.cursor  = plan4Count <= plan4MinCount ? 'not-allowed' : 'pointer';
    }

    // 同步 hidden quantity 字段
    document.querySelectorAll('#plan4-quantity-input').forEach(function(el) {
      el.value = plan4Count;
    });
  }
</script>
