                    <% end %>
                  <% else %>
                    <span class="text-muted/40 text-xs">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted text-sm font-mono">技能整理中，敬请期待…</p>
