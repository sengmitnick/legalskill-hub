<%# TECH AGENT HOME — Dark minimal, mission-control aesthetic %>

<%# Payment modal overlay — Turbo Stream fills #payment-modal-body on PC Native pay %>
<div id="payment-modal-overlay"
     class="hidden fixed inset-0 z-50 bg-black/60 backdrop-blur-sm"
     data-controller="wechat-pay-modal"
     data-action="click->wechat-pay-modal#backdropClick">
  <div id="payment-modal-body" data-wechat-pay-modal-target="body"></div>
</div>

<!-- HERO: Command Center -->
<section class="relative min-h-screen flex items-center bg-surface tech-grid-bg">
  <!-- Radial glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-1/3 w-96 h-96 rounded-full opacity-10"
         style="background: radial-gradient(circle, hsl(174 100% 44%) 0%, transparent 70%);"></div>
  </div>

  <div class="relative z-10 container-xl mx-auto px-4 sm:px-6 py-16 sm:py-24 text-center">
    <!-- 主标题 -->
    <div class="mb-8 sm:mb-12">
      <h1 class="font-mono text-3xl sm:text-4xl md:text-6xl font-bold leading-tight tracking-tight">
        <span class="text-secondary">让每一位律师拥有 </span><span style="color: hsl(174, 100%, 44%)">7x24 AI 助手</span>
      </h1>
    </div>

    <!-- CTA 按钮 -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
      <%= link_to "#pricing", class: "btn-outline btn-md font-mono text-sm tracking-widest inline-flex items-center justify-center gap-2 w-full sm:w-auto" do %>
        <%= lucide_icon "rocket", class: "w-4 h-4" %>
        <span>跟着镐赞养好龙虾</span>
      <% end %>
      <% if @hero_video_url.present? %>
        <a href="<%= video_resources_path %>"
          class="btn-md font-mono text-sm tracking-widest inline-flex items-center justify-center gap-2 w-full sm:w-auto"
          style="background: hsl(174,100%,44%); color: #0a0f0d; font-weight: 700;">
          <%= lucide_icon "play-circle", class: "w-4 h-4" %>
          <span>学习公开课</span>
        </a>
      <% end %>
    </div>


  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-0 right-0 z-20 flex justify-center animate-bounce">
    <div class="flex flex-col items-center gap-2">
      <span class="text-xs font-mono text-muted tracking-widest">向下滚动</span>
      <%= lucide_icon "chevron-down", class: "w-4 h-4 text-primary" %>
    </div>
  </div>
</section>

<% if @hero_video_url.present? %>
<!-- stimulus-validator: allow-script -->
<script>
  // ESC 键关闭技能演示弹窗
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeSkillVideo(); }
  });
</script>

<!-- 技能演示弹窗 -->
<div id="skill-video-modal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
     style="background: rgba(0,0,0,0.85);"
     onclick="if(event.target===this){closeSkillVideo()}">
  <div class="relative w-full max-w-4xl">
    <div class="flex items-center justify-between mb-3">
      <span id="skill-video-title" class="font-mono text-sm tracking-widest" style="color: hsl(174,100%,44%)"></span>
      <button onclick="closeSkillVideo()" class="text-muted hover:text-primary">
        <%= lucide_icon "x", class: "w-5 h-5" %>
      </button>
    </div>
    <div class="relative w-full" style="aspect-ratio: 16/9; background: #000; border-radius: 8px; overflow: hidden;">
      <video id="skill-video-player" src="" controls class="w-full h-full object-contain" style="display: block;"></video>
    </div>
  </div>
</div>

<!-- stimulus-validator: allow-script -->
<script>
  function openSkillVideo(url, title) {
    var modal = document.getElementById('skill-video-modal');
    var player = document.getElementById('skill-video-player');
    document.getElementById('skill-video-title').textContent = title;
    player.src = url;
    modal.classList.remove('hidden');
    player.play();
  }
  function closeSkillVideo() {
    var modal = document.getElementById('skill-video-modal');
    var player = document.getElementById('skill-video-player');
    modal.classList.add('hidden');
    player.pause();
    player.currentTime = 0;
    player.src = '';
  }
</script>
<% end %>
<!-- SECTION: 3 Reasons -->
<section id="reasons" class="py-20 bg-surface-elevated border-t border-border">
  <div class="container-xl mx-auto px-4 sm:px-6">
    <!-- Section Header -->
    <div class="mb-10 sm:mb-12 text-center">
      <h2 class="section-title !mb-0">3 点选择<span style="color: hsl(174, 100%, 44%)">青狮龙虾</span>的理由</h2>
      <p class="section-subtitle mt-2">专为律师而生，不是通用 AI 套壳</p>
    </div>

    <!-- Reasons Grid -->
    <div class="grid sm:grid-cols-3 gap-6 px-4 sm:px-0" style="grid-template-rows: auto;">

      <!-- 理由一 -->
      <div class="px-6 py-6 sm:px-8 sm:py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-6 sm:pb-10" style="font-size: clamp(4rem, 15vw, 7rem); color: hsl(174, 100%, 44%)">
          90%
        </div>
        <h3 class="font-mono text-base sm:text-lg font-bold text-primary pb-3 sm:pb-5 tracking-tight">省下一个助理的成本</h3>
        <p class="text-secondary text-sm leading-loose">
          处理卷宗、起草文书、整理庭审记录——过去需要一个助理干的活，龙虾全包。资深律师用龙虾，节省 90% 时间，省下一个助理的成本。
        </p>
      </div>

      <!-- 理由二 -->
      <div class="px-6 py-6 sm:px-8 sm:py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-6 sm:pb-10" style="font-size: clamp(4rem, 15vw, 7rem); color: hsl(174, 100%, 44%)">
          80%
        </div>
        <h3 class="font-mono text-base sm:text-lg font-bold text-primary pb-3 sm:pb-5 tracking-tight">拉平顶尖律师的专业差距</h3>
        <p class="text-secondary text-sm leading-loose">
          龙虾背后接入全球 Top 3 顶尖 AI 模型，让刚入行的律师也能用上行业大佬同等级的"法律脑"。跑赢 80% 的同行。
        </p>
      </div>

      <!-- 理由三 -->
      <div class="px-6 py-6 sm:px-8 sm:py-8" style="display: grid; grid-template-rows: subgrid; grid-row: span 3;">
        <div class="font-mono font-bold leading-none pb-6 sm:pb-10" style="font-size: clamp(4rem, 15vw, 7rem); color: hsl(174, 100%, 44%)">
          5×
        </div>
        <h3 class="font-mono text-base sm:text-lg font-bold text-primary pb-3 sm:pb-5 tracking-tight">拥有一个运营团队</h3>
        <p class="text-secondary text-sm leading-loose">
          公众号、小红书、视频脚本、文章、出书……龙虾帮你一个人撑起律师品牌的全部内容运营，相当于拥有一支 5 人运营团队。
        </p>
      </div>

    </div>
  </div>
</section>


<!-- SECTION: Pricing Table -->
