          <div class="text-xs text-muted tracking-widest uppercase font-mono">方案 1</div>
          <div class="text-xs text-muted/60">社群版 + 1 年期使用权</div>
        </div>
        <div class="flex items-baseline gap-3 mt-2 mb-3">
          <div class="text-2xl font-bold text-primary font-mono">999<span class="text-xs font-normal text-muted ml-1">元</span></div>
          <div class="text-xs text-muted font-mono" style="text-decoration:line-through;">原价 1999 元</div>
        </div>
        <ul class="text-xs text-secondary space-y-1 mb-4">
          <li>· 纯工具，1 人</li>
          <li>· 龙虾 1 只 / 1 年</li>
          <li>· 免费线上课 · 社群答疑</li>
        </ul>
        <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center justify-center gap-1.5 w-full" do %>
          <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
          立即购买
        <% end %>
      </div>

      <!-- 卡片2：方案二 -->
      <div class="border border-border bg-surface-elevated p-4 flex flex-col">
        <div class="flex items-baseline justify-between mb-1">
          <div class="text-xs text-muted tracking-widest uppercase font-mono">方案 2</div>
          <div class="text-xs text-muted/60">线上课程 + 1 年期</div>
        </div>
        <div class="flex items-baseline gap-3 mt-2 mb-3">
          <div class="text-2xl font-bold text-primary font-mono">1999<span class="text-xs font-normal text-muted ml-1">元</span></div>
        </div>
        <ul class="text-xs text-secondary space-y-1 mb-4">
          <li>· 线上课，1 人</li>
          <li>· 龙虾 1 只 / 1 年</li>
          <li>· 社群答疑 · 会议答疑 12 次+</li>
          <li>· 远程服务</li>
        </ul>
        <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center justify-center gap-1.5 w-full" do %>
          <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
          立即购买
        <% end %>
      </div>

      <!-- 卡片3：方案三（推荐） -->
      <div class="border p-4 flex flex-col" style="border-color:hsl(174,100%,44%); background:hsl(174,100%,44%,0.04);">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <div class="text-xs text-muted tracking-widest uppercase font-mono">方案 3</div>
            <span class="text-xs font-mono px-3 py-0.5" style="background:hsl(174,100%,44%); color:#0a0f0d;">推荐</span>
          </div>
          <div class="text-xs text-muted/60">线下课程 + 1 年期</div>
        </div>
        <!-- 价格行 -->
        <div class="flex items-center justify-between mb-1">
          <div>
            <span id="m-plan3-origin-price" class="text-xs text-muted font-mono invisible" style="text-decoration:line-through;">原价 2999 元</span>
            <div class="text-2xl font-bold font-mono" style="color:hsl(174,100%,44%);"><span id="m-plan3-total">2999</span><span class="text-xs font-normal text-muted ml-1">元/人</span></div>
            <div id="m-plan3-grand-total" class="text-xs text-muted invisible">&nbsp;</div>
          </div>
          <!-- 加减人数 -->
          <div class="flex flex-col items-center gap-1">
            <div class="flex items-center gap-3">
              <button type="button" onclick="updatePlan3(-1)"
                class="w-8 h-8 rounded-full flex items-center justify-center font-mono text-lg font-bold transition-all leading-none"
                style="background:hsl(174,100%,44%,0.15); color:hsl(174,100%,44%); border:1.5px solid hsl(174,100%,44%);">−</button>
              <span class="font-bold text-base w-12 text-center font-mono" style="color:hsl(174,100%,44%);"><span id="m-plan3-count">1</span> 人</span>
              <button type="button" onclick="updatePlan3(1)"
                class="w-8 h-8 rounded-full flex items-center justify-center font-mono text-lg font-bold transition-all leading-none"
                style="background:hsl(174,100%,44%); color:#0a0f0d; border:1.5px solid hsl(174,100%,44%);">+</button>
            </div>
            <div id="m-plan3-tip" class="text-xs font-mono text-center leading-4" style="color:hsl(174,100%,44%); opacity:0.85;">点击 +<br>享受团购价</div>
          </div>
        </div>
        <ul class="text-xs text-secondary space-y-1 my-3">
          <li>· 线下课，龙虾 <span id="m-plan3-lobster-count">1</span> 只 / 1 年</li>
          <li>· 社群答疑 · 会议答疑 12 次+</li>
          <li>· 远程服务 · 线下交付</li>
        </ul>
        <%= link_to wechat_qrcode_path, class: "btn-sm font-mono text-xs tracking-widest inline-flex items-center justify-center gap-1.5 w-full", style: "background:hsl(174,100%,44%); color:#0a0f0d; font-weight:700;" do %>
          <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
          立即购买
        <% end %>
      </div>

      <!-- 卡片4：方案四 -->
      <div class="border border-border bg-surface-elevated p-4 flex flex-col">
        <div class="flex items-center justify-between mb-3">
          <div class="text-xs text-muted tracking-widest uppercase font-mono">方案 4</div>
          <div class="text-xs text-muted/60">团队线下内训</div>
        </div>
        <!-- 价格行 -->
        <div class="flex items-center justify-between mb-1">
          <div>
            <div class="text-xs text-muted font-mono" style="text-decoration:line-through;">原价 2999 元/人</div>
            <div class="text-2xl font-bold text-primary font-mono"><span id="m-plan4-total">1999</span><span class="text-xs font-normal text-muted ml-1">元/人</span></div>
            <div id="m-plan4-grand-total" class="text-xs text-muted">共计 <span id="m-plan4-count-display">29,985</span> 元</div>
          </div>
          <!-- 加减人数 -->
          <div class="flex flex-col items-center gap-1">
            <div class="flex items-center gap-3">
              <button type="button" onclick="updatePlan4(-1)"
                class="w-8 h-8 rounded-full flex items-center justify-center font-mono text-lg font-bold transition-all leading-none"
                style="background:rgba(100,116,139,0.15); color:#64748b; border:1.5px solid #64748b;">−</button>
              <span class="font-bold text-base w-12 text-center text-primary font-mono whitespace-nowrap"><span id="m-plan4-count">15</span> 人</span>
              <button type="button" onclick="updatePlan4(1)"
                class="w-8 h-8 rounded-full flex items-center justify-center font-mono text-lg font-bold transition-all leading-none"
                style="background:#64748b; color:#fff; border:1.5px solid #64748b;">+</button>
            </div>
            <div id="m-plan4-tip" class="text-xs font-mono text-muted/70 text-center leading-4">最低 15 人起</div>
          </div>
        </div>
        <ul class="text-xs text-secondary space-y-1 my-3">
          <li>· 线下内训，<span id="m-plan4-lobster-count">15</span> 只龙虾 / 1 年</li>
          <li>· 社群答疑 · 会议答疑 12 次+</li>
          <li>· 远程服务 · 线下交付</li>
        </ul>
        <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center justify-center gap-1.5 w-full" do %>
          <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
          立即购买
        <% end %>
      </div>

    </div>
    <!-- ===== END 移动端卡片 ===== -->

    <!-- 定价对比表（sm及以上显示）-->
    <div class="hidden sm:block relative overflow-x-auto pt-6">

      <table class="w-full font-mono text-sm border-separate border-spacing-0 min-w-[600px]">
        <thead>
          <tr>
            <th class="text-left py-5 pr-6 text-muted font-normal tracking-widest text-xs uppercase w-1/5 border-b border-border"></th>

            <!-- 方案一 -->
            <th class="text-center py-4 px-2 sm:py-5 sm:px-4 border-b border-border w-[20%]">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案 1</div>
              <div class="text-xs sm:text-sm text-muted/60 mb-3 sm:mb-4">社群版 + 1 年期使用权</div>
              <div class="text-xs sm:text-sm text-muted font-mono mb-0" style="text-decoration: line-through;">原价 1999 元</div>
              <div class="text-sm mb-1 invisible">&nbsp;</div>
              <div class="text-2xl sm:text-3xl font-bold text-primary mb-1">999<span class="text-xs sm:text-sm font-normal text-muted ml-1">元</span></div>
              <div class="text-xs text-muted invisible mb-3">&nbsp;</div>
              <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </th>

            <!-- 方案二 -->
            <th class="text-center py-4 px-2 sm:py-5 sm:px-4 border-b border-border w-[20%]">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案 2</div>
              <div class="text-xs sm:text-sm text-muted/60 mb-3 sm:mb-4">线上课程 + 1 年期使用权</div>
              <div class="text-xs sm:text-sm text-muted line-through font-mono mb-0 invisible">&nbsp;</div>
              <div class="text-sm mb-1 invisible" aria-hidden="true">&nbsp;</div>
              <div class="text-2xl sm:text-3xl font-bold text-primary mb-1">1999<span class="text-xs sm:text-sm font-normal text-muted ml-1">元</span></div>
              <div class="text-xs text-muted invisible mb-3">&nbsp;</div>
              <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </th>

            <!-- 方案三 -->
            <th class="text-center py-4 px-2 sm:py-5 sm:px-4 border-b w-[20%]" style="border-color: hsl(174,100%,44%); background: hsl(174,100%,44%,0.04);">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案 3</div>
              <div class="text-xs sm:text-sm text-muted/60 mb-3 sm:mb-4">线下课程 + 1 年期使用权</div>
              <div id="plan3-origin-price" class="text-xs sm:text-sm text-muted font-mono mb-0 invisible" style="text-decoration: line-through;">&nbsp;</div>
              <div class="text-xs mb-1 invisible">&nbsp;</div>
              <div class="text-2xl sm:text-3xl font-bold mb-1" style="color: hsl(174,100%,44%)">
                <span id="plan3-total">2999</span><span class="text-xs sm:text-sm font-normal text-muted ml-1">元/人</span>
              </div>
              <div id="plan3-grand-total" class="text-xs text-muted invisible mb-3">&nbsp;</div>
              <%= link_to wechat_qrcode_path, class: "btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center", style: "background: hsl(174,100%,44%); color: #0a0f0d; font-weight: 700;" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </th>

            <!-- 方案四 -->
            <th class="text-center py-4 px-2 sm:py-5 sm:px-4 border-b border-border w-[20%]">
              <div class="text-xs text-muted tracking-widest uppercase mb-2">方案 4</div>
              <div class="text-xs sm:text-sm text-muted/60 mb-3 sm:mb-4">团队线下内训</div>
              <div class="text-xs sm:text-sm text-muted font-mono mb-0" style="text-decoration: line-through;">原价 2999 元</div>
              <div class="text-xs mb-1 invisible">&nbsp;</div>
              <div class="text-2xl sm:text-3xl font-bold text-primary mb-1">
                <span id="plan4-total">1999</span><span class="text-xs sm:text-sm font-normal text-muted ml-1">元/人</span>
              </div>
              <div id="plan4-grand-total" class="text-xs text-muted mb-3">共计 <span id="plan4-count-display">29,985</span> 元</div>
              <%= link_to wechat_qrcode_path, class: "btn-outline btn-sm font-mono text-xs tracking-widest inline-flex items-center gap-1.5 w-full justify-center" do %>
                <%= lucide_icon "shopping-cart", class: "w-3.5 h-3.5" %>
                立即购买
              <% end %>
            </th>
          </tr>
        </thead>

        <tbody>
          <%
            rows = [
              # [行标签,        方案一值,         方案二值,              方案三值,              方案四值,          是否分组标题]
              ["服务形式",      "纯工具",          "线上课",              "线下课",     "团队线下内训", false],
              ["龙虾数量",  "青狮龙虾 1 只",   "青狮龙虾 1 只",       "青狮龙虾 1 只",       "青狮龙虾 15 只",   false],
              ["参加人数",          "1 人",            "1 人",                "1 人",                "≤ 15 人",         false],
              ["龙虾期限",  "1 年",            "1 年",                "1 年",                "1 年",            false],
              ["线上视频",  "免费课",               "✅",                  "✅",                  "✅",               false],
              ["社群答疑",  "✅",               "✅",                  "✅",                  "✅",               false],
              ["会议答疑",  "—",               "> 12 次/年",          "> 12 次/年",          "> 12 次/年",      false],
              ["远程服务",      "—",               "✅",                  "✅",                  "✅",               false],
              ["线下交付","—",               "—",                   "✅",                  "✅",               false],
            ]
          %>
          <% rows.each_with_index do |(label, v1, v2, v3, v4, is_group), i| %>
            <% if is_group %>
              <tr>
                <td colspan="5" class="pt-8 pb-3 text-base font-bold tracking-widest text-center border-b border-border/30" style="color: hsl(174,100%,44%)">
                  <%= label %>
                </td>
              </tr>
            <% elsif label == "龙虾数量" %>
              <tr class="<%= i.even? ? 'bg-surface-elevated/20' : '' %>">
                <td class="py-3 pr-6 text-sm font-mono font-medium text-primary border-b border-border/30"><%= label %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= v1 %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= v2 %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 font-semibold" style="background: hsl(174,100%,44%,0.04);">
                  <span id="plan3-lobster-count">青狮龙虾 1 只</span>
                </td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary">
                  <span id="plan4-lobster-count">青狮龙虾 15 只</span>
                </td>
              </tr>
            <% elsif label == "参加人数" %>
              <tr class="<%= i.even? ? 'bg-surface-elevated/20' : '' %>">
                <td class="py-3 pr-6 text-sm font-mono font-medium text-primary border-b border-border/30"><%= label %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= v1 %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= v2 %></td>
                <td class="py-3 px-3 text-center border-b border-border/30" style="background: hsl(174,100%,44%,0.10);">
                  <div class="flex items-center justify-center gap-2 mb-1">
                    <button type="button" id="plan3-minus" onclick="updatePlan3(-1)"
                      class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-base font-bold transition-all leading-none"
                      style="background: hsl(174,100%,44%,0.15); color: hsl(174,100%,44%); border: 1.5px solid hsl(174,100%,44%);">−</button>
                    <span class="font-bold text-lg w-10 text-center" style="color: hsl(174,100%,44%);"><span id="plan3-count">1</span> 人</span>
                    <button type="button" id="plan3-plus" onclick="updatePlan3(1)"
                      class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-base font-bold transition-all leading-none"
                      style="background: hsl(174,100%,44%); color: #0a0f0d; border: 1.5px solid hsl(174,100%,44%);">+</button>
                  </div>
                  <div id="plan3-tip" class="text-xs font-mono leading-5" style="color: hsl(174,100%,44%); opacity: 0.85;">点击 +<br>享受团购价</div>
                </td>
                <td class="py-2 px-3 text-center border-b border-border/30">
                  <div class="flex items-center justify-center gap-2 mb-1">
                    <button type="button" id="plan4-minus" onclick="updatePlan4(-1)"
                      class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-base font-bold transition-all leading-none"
                      style="background: rgba(100,116,139,0.15); color: #64748b; border: 1.5px solid #64748b;">−</button>
                    <span class="font-bold text-lg w-16 text-center text-primary whitespace-nowrap"><span id="plan4-count">15</span> 人</span>
                    <button type="button" id="plan4-plus" onclick="updatePlan4(1)"
                      class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-base font-bold transition-all leading-none"
