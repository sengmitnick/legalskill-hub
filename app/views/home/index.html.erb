        <%= buy_button(plan: "plan3", css_class: "btn-sm font-mono text-xs tracking-widest inline-flex items-center justify-center gap-1.5 w-full", style: "background:hsl(174,100%,44%); color:#0a0f0d; font-weight:700;") %>
