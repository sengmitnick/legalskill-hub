                    <div style="display:flex; align-items:center; gap:8px; min-width:120px;">
                      <div style="flex:1; height:6px; background:rgba(128,128,128,0.2); border-radius:9999px; overflow:hidden;">
                        <div style="height:6px; border-radius:9999px; background:hsl(174,100%,44%); width:<%= skill.ai_completion %>%;"></div>
                      </div>
                      <span style="font-size:12px; font-family:monospace; color:hsl(174,100%,44%); min-width:32px; text-align:right;"><%= skill.ai_completion %>%</span>
                    </div>
                  <% else %>
                    <span class="text-muted/40 text-sm">—</span>
                  <% end %>
