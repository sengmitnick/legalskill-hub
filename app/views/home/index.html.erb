        <table class="min-w-full divide-y divide-border">
          <thead>
            <tr class="bg-surface-elevated">
              <th class="px-3 sm:px-5 py-3 text-left text-xs font-mono font-medium text-muted uppercase tracking-widest w-10 sm:w-16 whitespace-nowrap">序号</th>
              <th class="px-3 sm:px-5 py-3 text-left text-xs font-mono font-medium text-muted uppercase tracking-widest whitespace-nowrap">技能名称</th>
              <th class="px-5 py-3 text-left text-xs font-mono font-medium text-muted uppercase tracking-widest whitespace-nowrap">使用场景</th>
              <th class="px-5 py-3 text-left text-xs font-mono font-medium text-muted uppercase tracking-widest whitespace-nowrap">AI 完成度</th>
              <th class="px-5 py-3 text-center text-xs font-mono font-medium text-muted uppercase tracking-widest whitespace-nowrap">演示</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @delivered_skills.each_with_index do |skill, idx| %>
              <tr class="<%= idx.even? ? 'bg-surface' : 'bg-surface-elevated/30' %> hover:bg-primary/5 transition-colors">
                <td class="px-3 sm:px-5 py-4 text-sm font-mono font-bold text-muted/60">
                  <%= "%02d" % (idx + 1) %>
                </td>
