              # [行标签,        方案一值,         方案二值,              方案三值,              方案四值,          是否分组标题]
              ["适合人群",      "自带技术感<br>能自主探索工具的独立律师",   "想系统掌握龙虾<br>跟着镐赞学满一年",   "想快速上手<br>面对面解决所有疑问 ⭐",   "整个团队一起提效<br>适合律所或区域律师群体",   false],
              ["龙虾数量",  "青狮龙虾 1 只",   "青狮龙虾 1 只",       "青狮龙虾 1 只",       "青狮龙虾 15 只",   false],
              ["参加人数",          "1 人",            "1 人",                "1 人",                "≤ 15 人",         false],
              ["参加地区",          "__placeholder__", "__placeholder__",     "__placeholder__",     "__placeholder__", false],
              ["龙虾期限",  "1 年",            "1 年",                "1 年",                "1 年",            false],
              ["线上课程",  "公开课",               "进阶课程",            "进阶课程",            "进阶课程",            false],
              ["社群答疑",  "✅",               "✅",                  "✅",                  "✅",               false],
              ["会议答疑",  "—",               "> 12 次/年",          "> 12 次/年",          "> 12 次/年",      false],
              ["远程服务",      "—",               "✅",                  "✅",                  "✅",               false],
              ["线下交付","—",               "—",                   "✅",                  "✅",               false],
            ]
          %>
          <% rows.each_with_index do |(label, v1, v2, v3, v4, is_group), i| %>
            <% if is_group %>
              <tr>
                <td colspan="5" class="pt-8 pb-3 text-base font-bold tracking-widest text-center border-b border-border/30" style="color: hsl(174,100%,44%)">
                  <%= label %>
                </td>
              </tr>
            <% elsif label == "龙虾数量" %>
              <tr class="<%= i.even? ? 'bg-surface-elevated/20' : '' %>">
                <td class="py-3 pr-6 text-sm font-mono font-medium text-primary border-b border-border/30"><%= label %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= v1 %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= v2 %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 font-semibold" style="background: hsl(174,100%,44%,0.04);">
                  <span id="plan3-lobster-count">青狮龙虾 1 只</span>
                </td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary">
                  <span id="plan4-lobster-count">青狮龙虾 15 只</span>
                </td>
              </tr>
            <% elsif label == "参加人数" %>
              <tr class="<%= i.even? ? 'bg-surface-elevated/20' : '' %>">
                <td class="py-3 pr-6 text-sm font-mono font-medium text-primary border-b border-border/30"><%= label %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= v1 %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= v2 %></td>
                <td class="py-3 px-3 text-center border-b border-border/30" style="background: hsl(174,100%,44%,0.10);">
                  <div class="flex items-center justify-center gap-2 mb-1">
                    <button type="button" id="plan3-minus" onclick="updatePlan3(-1)"
                      class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-base font-bold transition-all leading-none"
                      style="background: hsl(174,100%,44%,0.15); color: hsl(174,100%,44%); border: 1.5px solid hsl(174,100%,44%);">−</button>
                    <span class="font-bold text-lg w-10 text-center" style="color: hsl(174,100%,44%);"><span id="plan3-count">1</span> 人</span>
                    <button type="button" id="plan3-plus" onclick="updatePlan3(1)"
                      class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-base font-bold transition-all leading-none"
                      style="background: hsl(174,100%,44%); color: #0a0f0d; border: 1.5px solid hsl(174,100%,44%);">+</button>
                  </div>
                  <div id="plan3-tip" class="text-xs font-mono leading-5" style="color: hsl(174,100%,44%); opacity: 0.85;">点击 +<br>享受团购价</div>
                </td>
                <td class="py-2 px-3 text-center border-b border-border/30">
                  <div class="flex items-center justify-center gap-2 mb-1">
                    <button type="button" id="plan4-minus" onclick="updatePlan4(-1)"
                      class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-base font-bold transition-all leading-none"
                      style="background: rgba(100,116,139,0.15); color: #64748b; border: 1.5px solid #64748b;">−</button>
                    <span class="font-bold text-lg w-16 text-center text-primary whitespace-nowrap"><span id="plan4-count">15</span> 人</span>
                    <button type="button" id="plan4-plus" onclick="updatePlan4(1)"
                      class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-base font-bold transition-all leading-none"
                      style="background: #64748b; color: #fff; border: 1.5px solid #64748b;">+</button>
                  </div>
                  <div id="plan4-tip" class="text-xs font-mono text-muted/70 leading-5">最低 15 人<br>起</div>
                </td>
              </tr>
            <% elsif label == "参加地区" %>
              <tr class="<%= i.even? ? 'bg-surface-elevated/20' : '' %>">
                <td class="py-3 pr-6 text-sm font-mono font-medium text-primary border-b border-border/30">参加地区</td>
                <%# 方案一：微信社群 %>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary">微信社群</td>
                <%# 方案二：线上课程 %>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary">线上课程</td>
                <%# 方案三：动态班次列表 %>
                <td class="py-2 px-3 text-center text-xs border-b border-border/30 font-semibold leading-relaxed" style="background: hsl(174,100%,44%,0.04);">
                  <a href="#offline-classes" class="block hover:underline underline-offset-2 transition-opacity hover:opacity-80" style="color: hsl(174,100%,44%);">
                    <% @offline_classes.each do |oc| %>
                      <div class="py-0.5"><span class="font-mono"><%= oc.date.strftime("%m 月 %d 日") %></span>｜<%= oc.city %>站</div>
                    <% end %>
                  </a>
                </td>
                <%# 方案四：由内训负责人确定 %>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary">由内训负责人确定</td>
              </tr>
            <% else %>
              <tr class="<%= i.even? ? 'bg-surface-elevated/20' : '' %>">
                <td class="py-3 pr-6 text-sm font-mono font-medium text-primary border-b border-border/30"><%= label %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= raw v1.to_s.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= raw v2.to_s.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 font-semibold" style="background: hsl(174,100%,44%,0.04);"><%= raw v3.to_s.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
                <td class="py-3 px-4 text-center text-sm border-b border-border/30 text-secondary"><%= raw v4.to_s.gsub("✅", "<span style='color:hsl(174,100%,44%)'>✓</span>") %></td>
              </tr>
            <% end %>
          <% end %>


        </tbody>
      </table>
    </div>
    <!-- END hidden sm:block -->

    <!-- 底部补充说明 -->
    <p class="text-center text-xs font-mono text-muted/60 mt-8">
      支持发票 · 支持公户付款
    </p>

  </div>
</section>

<!-- SECTION: 交付技能 -->
<section id="delivered-skills" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">

    <!-- Section Header -->
    <div class="mb-10 text-center">
      <h2 class="font-mono text-3xl md:text-4xl font-bold text-primary tracking-tight mb-3">
        交付 <%= @delivered_skills.count %> 项龙虾技能
        <span class="inline-flex items-center gap-1 ml-2 px-2 py-0.5 text-xs font-mono font-normal rounded-full align-middle" style="background: hsl(174,100%,44%,0.12); color: hsl(174,100%,44%); border: 1px solid hsl(174,100%,44%,0.3);">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse inline-block" style="background: hsl(174,100%,44%)"></span>
          持续增加中
        </span>
      </h2>
      <p class="text-secondary text-base max-w-xl mx-auto">每一个 Skill 均由律师参与设计，覆盖真实执业场景——交付即可上手，开箱即用</p>
    </div>

    <% if @delivered_skills.any? %>

      <!-- 手机端：卡片列表 -->
      <div class="md:hidden flex flex-col gap-3">
        <% @delivered_skills.each_with_index do |skill, idx| %>
          <div class="rounded-xl border border-border bg-surface-elevated/30 px-4 py-4">
            <!-- 顶部：序号 + 名称 + 演示按钮 -->
            <div class="flex items-center justify-between gap-2 mb-3">
              <div class="flex items-center gap-2.5 min-w-0">
                <span class="font-mono text-xs font-bold text-muted/50 shrink-0"><%= "%02d" % (idx + 1) %></span>
                <span class="text-sm font-semibold text-primary truncate"><%= skill.name %></span>
              </div>
              <% if skill.demo_video_url.present? %>
                <button onclick="openSkillVideo('<%= j skill.demo_video_url %>', '<%= j skill.name %>')"
                    class="inline-flex items-center gap-1 text-xs font-mono text-primary hover:text-primary-light transition-colors shrink-0">
                  <%= lucide_icon "play-circle", class: "w-4 h-4" %>
                  <span>演示</span>
                </button>
              <% end %>
            </div>
            <!-- 使用场景 -->
            <% if skill.scenario.present? %>
              <p class="text-xs text-secondary mb-3 leading-relaxed"><%= skill.scenario %></p>
            <% end %>
            <!-- AI 完成度 -->
            <% if skill.ai_completion.present? %>
              <div class="flex items-center gap-2">
                <span class="text-xs font-mono text-muted/60 shrink-0">青狮龙虾为你节约的时间</span>
                <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background:rgba(128,128,128,0.2)">
                  <div class="h-1.5 rounded-full" style="background:hsl(174,100%,44%); width:<%= skill.ai_completion %>%"></div>
                </div>
                <span class="text-xs font-mono shrink-0" style="color:hsl(174,100%,44%)">节约 <%= skill.ai_completion %>% 的时间</span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- 桌面端：表格 -->
      <div class="hidden md:block overflow-x-auto rounded-xl border border-border">
        <table class="min-w-full divide-y divide-border">
          <thead>
            <tr class="bg-surface-elevated border-b-2 border-primary">
              <th class="px-5 py-4 text-left text-sm font-mono font-bold text-primary tracking-widest w-16 whitespace-nowrap">序号</th>
              <th class="px-5 py-4 text-left text-sm font-mono font-bold text-primary tracking-widest whitespace-nowrap">技能名称</th>
              <th class="px-5 py-4 text-left text-sm font-mono font-bold text-primary tracking-widest whitespace-nowrap">使用场景</th>
              <th class="px-5 py-4 text-left text-sm font-mono font-bold text-primary tracking-widest whitespace-nowrap">青狮龙虾为你节约的时间</th>
              <th class="px-5 py-4 text-center text-sm font-mono font-bold text-primary tracking-widest whitespace-nowrap">演示</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @delivered_skills.each_with_index do |skill, idx| %>
              <tr class="<%= idx.even? ? 'bg-surface' : 'bg-surface-elevated/30' %> hover:bg-primary/5 transition-colors">
                <td class="px-5 py-4 text-sm font-mono font-bold text-muted/60">
                  <%= "%02d" % (idx + 1) %>
                </td>
                <td class="px-5 py-4 text-sm font-semibold text-primary">
                  <%= skill.name %>
                </td>
                <td class="px-5 py-4 text-sm text-secondary max-w-xs">
                  <%= skill.scenario.present? ? skill.scenario : "—" %>
                </td>
                <td class="px-5 py-4">
                  <% if skill.ai_completion.present? %>
                    <div style="display:flex; align-items:center; gap:8px; min-width:120px;">
                      <div style="flex:1; height:6px; background:rgba(128,128,128,0.2); border-radius:9999px; overflow:hidden;">
                        <div style="height:6px; border-radius:9999px; background:hsl(174,100%,44%); width:<%= skill.ai_completion %>%;"></div>
                      </div>
                      <span style="font-size:12px; font-family:monospace; color:hsl(174,100%,44%); min-width:32px; text-align:right;">节约 <%= skill.ai_completion %>% 的时间</span>
                    </div>
                  <% else %>
                    <span class="text-muted/40 text-sm">—</span>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-center">
                  <% if skill.demo_video_url.present? %>
                    <button onclick="openSkillVideo('<%= j skill.demo_video_url %>', '<%= j skill.name %>')"
                        class="inline-flex items-center gap-1 text-xs font-mono text-primary hover:text-primary-light transition-colors">
                      <%= lucide_icon "play-circle", class: "w-4 h-4" %>
                      <span>演示</span>
                    </button>
                  <% else %>
                    <span class="text-muted/40 text-xs">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

    <% else %>
      <p class="text-muted text-sm font-mono">技能整理中，敬请期待…</p>
    <% end %>

  </div>
</section>

<!-- SECTION: 线下课程班次 -->
<% if @offline_classes.any? %>
<section id="offline-classes" class="py-16 sm:py-20 bg-surface-elevated border-t border-border">
  <div class="container-xl mx-auto px-6">

    <!-- 标题 -->
    <div class="mb-10 text-center">
      <div class="flex items-center justify-center gap-3 mb-3">
        <h2 class="font-mono text-3xl md:text-4xl font-bold text-primary tracking-tight">线下课程</h2>

      </div>
      <p class="text-secondary text-base max-w-xl mx-auto">面对面系统学习青狮龙虾实战技能，每期限 10 人，小班精讲</p>
      <% unless user_signed_in? %>
        <%= link_to "#pricing", class: "inline-flex items-center gap-1.5 mt-3 px-4 py-1.5 rounded-full border border-primary/40 text-sm font-semibold text-primary hover:bg-primary/10 transition-colors" do %>
          购买后 方可报名
          <%= lucide_icon "arrow-right", class: "w-3.5 h-3.5" %>
        <% end %>
      <% end %>
      <% if user_signed_in? && @plan3_order.nil? %>
        <p class="text-xs mt-2" style="color: hsl(174,100%,44%); opacity: 0.8;">· 你尚未购买方案三，无法报名线下班次</p>
      <% end %>
      <% if @plan3_order %>
        <p class="text-xs mt-2 font-mono" style="color: hsl(174,100%,44%);">· 已购线下课程（<%= @plan3_order.quantity %> 人），点击「报名」即可</p>
      <% end %>
    </div>

    <!-- 班次卡片列表 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @offline_classes.each do |oc| %>
        <div id="offline-class-<%= oc.id %>" class="relative rounded-xl border border-border bg-surface p-5 flex flex-col gap-3 hover:border-primary/40 transition-colors">

          <!-- 状态标签 -->
          <% if oc.full? %>
            <span class="absolute top-4 right-4 text-xs font-mono px-2 py-0.5 rounded bg-orange-500/10 text-orange-500 border border-orange-500/30">已满</span>
          <% else %>
            <span class="absolute top-4 right-4 text-xs font-mono px-2 py-0.5 rounded" style="background: hsl(174,100%,44%,0.1); color: hsl(174,100%,44%); border: 1px solid hsl(174,100%,44%,0.3);">报名中</span>
          <% end %>

          <!-- 标题 -->
          <h3 class="font-bold text-base text-primary pr-16 leading-snug"><span class="font-mono"><%= oc.date.strftime("%m 月 %d 日") %></span>｜<%= oc.city %>站</h3>

          <!-- 信息行 -->
          <div class="space-y-1.5 text-sm text-secondary">
            <div class="flex items-center gap-2">
              <%= lucide_icon "calendar", class: "w-3.5 h-3.5 text-muted flex-shrink-0" %>
              <span class="font-mono"><%= oc.date.strftime("%Y 年 %m 月 %d 日") %></span>
            </div>
            <div class="flex items-center gap-2">
              <%= lucide_icon "map-pin", class: "w-3.5 h-3.5 text-muted flex-shrink-0" %>
              <span><%= oc.city %> · <%= oc.location %></span>
            </div>
            <div class="flex items-center gap-2">
              <%= lucide_icon "users", class: "w-3.5 h-3.5 text-muted flex-shrink-0" %>
              <span>
                <span class="font-mono font-bold <%= oc.full? ? 'text-orange-500' : 'text-primary' %>"><%= oc.spots_remaining %></span>
                <span class="text-muted"> / <%= oc.capacity %> 名额剩余</span>
              </span>
            </div>
          </div>

          <% if oc.description.present? %>
            <p class="text-xs text-muted leading-relaxed border-t border-border pt-2"><%= oc.description %></p>
          <% end %>

          <!-- 报名按钮区 -->
          <div class="mt-auto pt-1">
            <% if !user_signed_in? %>
              <%= link_to sign_in_path, class: "btn-sm w-full text-center font-mono text-xs tracking-widest inline-flex items-center justify-center gap-1.5 border border-border text-muted hover:text-primary hover:border-primary transition-colors" do %>
                登录后报名
              <% end %>
            <% elsif oc.enrolled?(current_user) %>
              <div class="text-center text-xs font-mono py-2 rounded-lg border border-border text-secondary">
                ✅ 已报名（<%= oc.offline_class_enrollments.find_by(user: current_user)&.attendee_count %> 人）
              </div>
            <% elsif @plan3_order.nil? %>
              <div class="text-center text-xs font-mono py-2 rounded-lg border border-border/50 text-muted cursor-not-allowed">
                需购买方案三
              </div>
            <% elsif oc.full? %>
              <div class="text-center text-xs font-mono py-2 rounded-lg border border-orange-500/30 text-orange-500">
                班次已满
              </div>
            <% else %>
              <%= button_to enroll_offline_class_path(oc),
                  method: :post,
                  class: "w-full btn-sm font-mono text-xs tracking-widest inline-flex items-center justify-center gap-1.5",
                  style: "background: hsl(174,100%,44%); color: #0a0f0d; font-weight: 700;",
                  data: { turbo_confirm: "确认报名「#{oc.title}」（共 #{@plan3_order.quantity} 人）？" } do %>
                <%= lucide_icon "check-circle", class: "w-3.5 h-3.5" %>
                报名（<%= @plan3_order.quantity %> 人）
              <% end %>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>

  </div>
</section>
<% end %>
<!-- SECTION: Video Resources -->
<section id="video-resources" class="py-20 bg-surface border-t border-border">
  <div class="container-xl mx-auto px-6">
    <!-- Section Header -->
    <div class="mb-12 text-center">
      <h2 class="section-title !mb-0">线上课程</h2>
      <p class="section-subtitle mt-2">实战性的龙虾技能使用视频，掌握核心技能</p>
    </div>

    <!-- Category Filter -->
    <% video_categories = Category.for_video.order(:name) %>
    <% if video_categories.any? %>
    <div class="flex flex-wrap gap-2 mb-10">
      <%= link_to video_resources_path, class: "category-pill active" do %>全部<% end %>
      <% video_categories.each do |category| %>
        <%= link_to video_resources_path(category: category.slug), class: "category-pill" do %>
          <%= category.name %>
        <% end %>
      <% end %>
    </div>
    <% end %>

    <!-- Video Grid -->
    <% videos = VideoResource.includes(:category).order(created_at: :desc).limit(3) %>
    <% home_can_watch_premium = user_signed_in? && current_user.has_premium_video_access? %>
    <% if videos.any? %>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
      <% videos.each do |video| %>
      <% locked = !video.free? && !home_can_watch_premium %>
      <div class="video-card bg-surface-elevated">
        <div class="video-thumbnail">
          <img src="<%= video.cover_image_url %>"
               alt="<%= video.title %>"
               class="w-full h-full object-cover"
               referrerpolicy="no-referrer"
               onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1505664194779-8beaceb93744?w=600&h=340&fit=crop&q=80';">
          <% if locked %>
            <button type="button"
                    onclick="alert('此视频为进阶课程，需购买线上课程、线下课程或团队内训后才能观看。')"
                    class="absolute inset-0 flex items-center justify-center hover:bg-primary/5 transition-colors cursor-pointer w-full">
              <div class="w-12 h-12 border border-border flex items-center justify-center bg-surface/80">
                <%= lucide_icon "lock", class: "w-5 h-5 text-primary" %>
              </div>
            </button>
          <% else %>
            <%= link_to video_resource_path(video),
                  class: "absolute inset-0 flex items-center justify-center hover:bg-primary/5 transition-colors" do %>
              <div class="w-12 h-12 border border-primary flex items-center justify-center bg-surface/80 hover:bg-primary/20 transition-colors cursor-pointer">
                <%= lucide_icon "play", class: "w-5 h-5 text-primary ml-0.5" %>
              </div>
            <% end %>
          <% end %>
          <% if video.duration.present? %>
          <div class="absolute top-3 right-3 px-2 py-0.5 bg-surface/90 border border-border text-xs font-mono text-muted">
            <%= video.duration %>
          </div>
          <% end %>
          <div class="absolute bottom-0 left-0 right-0 h-px bg-primary/40"></div>
        </div>
        <div class="p-5">
          <div class="sys-label mb-2"><%= video.category.name.upcase %></div>
          <% if locked %>
            <button type="button"
                    onclick="alert('此视频为进阶课程，需购买线上课程、线下课程或团队内训后才能观看。')"
                    class="block text-left w-full">
              <h3 class="font-sans text-base font-semibold text-primary mb-2 hover:text-primary-light transition-colors cursor-pointer"><%= video.title %></h3>
            </button>
          <% else %>
            <%= link_to video_resource_path(video), class: "block group" do %>
              <h3 class="font-sans text-base font-semibold text-primary mb-2 group-hover:text-primary-light transition-colors"><%= video.title %></h3>
            <% end %>
          <% end %>
          <div class="flex items-center justify-between text-xs font-mono text-muted border-t border-border pt-3">
            <span><%= lucide_icon "folder", class: "w-3 h-3 inline" %> <%= video.category.name %></span>
            <% if locked %>
              <span><%= lucide_icon "lock", class: "w-3 h-3 inline" %> 需购买课程</span>
            <% else %>
              <span><%= lucide_icon "eye", class: "w-3 h-3 inline" %> <%= number_with_delimiter(video.views_count) %></span>
            <% end %>
          </div>
        </div>
      </div>
      <% end %>
    </div>

    <div class="mt-8 text-center">
      <%= link_to video_resources_path, class: "btn-outline btn-md inline-flex items-center gap-2 font-mono text-xs tracking-widest" do %>
        <span>加载更多视频</span>
        <%= lucide_icon "arrow-right", class: "w-3 h-3" %>
      <% end %>
    </div>
    <% end %>
  </div>
</section>

