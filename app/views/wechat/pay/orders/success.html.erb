<div class="container-sm py-16">
  <div class="card text-center">
    <div class="card-body space-y-6 py-12">
      <div class="flex justify-center">
        <div class="w-20 h-20 rounded-full bg-[hsl(var(--color-success)/0.15)] flex items-center justify-center">
          <%= lucide_icon "check-circle", class: "w-10 h-10 text-success" %>
        </div>
      </div>

      <div class="space-y-2">
        <h1 class="text-2xl font-bold text-primary">支付成功！</h1>
        <p class="text-secondary text-sm">感谢您的支持</p>
      </div>

      <!-- 添加创始人微信 -->
      <div class="flex flex-col items-center gap-3">
        <p class="text-sm font-semibold text-primary">务必添加创始人镐赞的微信</p>
        <div class="w-44 h-44 bg-surface border border-primary/20 p-2.5">
          <%= image_tag "qingshiying-qrcode.png",
              alt: "创始人镐赞微信二维码",
              class: "w-full h-full object-contain" %>
        </div>
      </div>

      <% if @order %>
        <div class="py-4 px-6 rounded-xl bg-[hsl(var(--color-surface-elevated))] space-y-2 text-left">
          <div class="flex justify-between text-sm">
            <span class="text-muted">订单号</span>
            <span class="text-secondary font-mono text-xs"><%= @order.out_trade_no %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-muted">支付金额</span>
            <span class="text-primary font-semibold font-mono">¥<%= sprintf("%.2f", @order.amount_yuan) %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-muted">支付时间</span>
            <span class="text-secondary"><%= (@order.paid_at || @order.updated_at).in_time_zone("Beijing").strftime("%Y-%m-%d %H:%M") %></span>
          </div>
        </div>
      <% end %>

      <div class="flex flex-col gap-3">
        <%= link_to my_tools_path, class: "btn-primary btn-md w-full" do %>
          <%= lucide_icon "key", class: "w-4 h-4" %>
          <span>进入「我的工具」领取青狮龙虾序列号</span>
        <% end %>
        <%= link_to root_path, class: "btn-outline btn-md w-full" do %>
          <%= lucide_icon "home", class: "w-4 h-4" %>
          <span>返回首页</span>
        <% end %>
      </div>
    </div>
  </div>
</div>
