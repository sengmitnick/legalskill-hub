<div class="flex items-center justify-center min-h-screen p-4"
     data-controller="wechat-pay-modal">
  <div class="relative bg-surface-elevated border border-border rounded-2xl shadow-2xl w-full max-w-sm p-8 text-center">
    <button type="button"
            class="absolute top-3 right-3 text-muted hover:text-secondary"
            data-action="click->wechat-pay-modal#close">
      <%= lucide_icon "x", class: "w-5 h-5" %>
    </button>
    <div class="flex flex-col items-center gap-3">
      <%= lucide_icon "alert-circle", class: "w-10 h-10 text-destructive" %>
      <p class="text-sm text-secondary"><%= message %></p>
    </div>
  </div>
</div>
