<% content_for :turbo_cache do %><meta name="turbo-cache-control" content="no-cache"><% end %>
<%# 注册页 — 统一引导微信扫码登录，无需单独注册 %>
<div class="min-h-screen bg-surface tech-grid-bg flex items-center justify-center px-4">
  <!-- Glow -->
  <div class="fixed inset-0 pointer-events-none"
       style="background: radial-gradient(ellipse 60% 50% at 50% 30%, hsl(174 100% 44% / 0.05) 0%, transparent 70%);"></div>

  <div class="relative w-full max-w-sm">
    <!-- Panel header -->
    <div class="bg-surface-elevated border border-border border-b-0 px-6 py-4 flex items-center gap-3">
      <div class="flex gap-1.5">
        <div class="w-2.5 h-2.5 rounded-full bg-border"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-primary/60"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-border"></div>
      </div>
      <span class="font-mono text-xs text-muted tracking-widest">认证 :: 新用户</span>
    </div>

    <!-- Panel body -->
    <div class="bg-surface-elevated border border-border px-8 py-10 text-center">

      <!-- Icon -->
      <div class="flex justify-center mb-6">
        <div class="w-16 h-16 border border-primary/30 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-primary">
            <path d="M8.5 4a6.5 6.5 0 0 0-1.56 12.81C7.3 17 7.5 17.16 7.5 17.5v.5a.5.5 0 0 0 .72.45l1.5-.75a1 1 0 0 1 .45-.1 8.56 8.56 0 0 0 1.33.1C11.5 17.7 11 16.9 11 16c0-2.76 2.69-5 6-5 .34 0 .67.02 1 .07A6.5 6.5 0 0 0 8.5 4z"/>
            <path d="M17 13c-2.21 0-4 1.57-4 3.5S14.79 20 17 20a5.4 5.4 0 0 0 1.08-.11.5.5 0 0 1 .35.06l1.07.54a.3.3 0 0 0 .43-.32l-.2-.9a.5.5 0 0 1 .14-.46C20.55 18.33 21 17.45 21 16.5 21 14.57 19.21 13 17 13z"/>
          </svg>
        </div>
      </div>

      <div class="sys-label mb-2">// 无需单独注册</div>
      <h1 class="font-mono text-xl font-bold text-primary mb-3">微信扫码即可登录</h1>
      <p class="text-xs font-mono text-muted leading-relaxed mb-8">
        首次扫码将自动为您创建账号<br>
        无需填写邮箱或密码，安全又便捷
      </p>

      <%= link_to sign_in_path, class: "btn-primary w-full btn-lg font-mono text-xs tracking-widest inline-flex items-center justify-center gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
          <path d="M8.5 4a6.5 6.5 0 0 0-1.56 12.81C7.3 17 7.5 17.16 7.5 17.5v.5a.5.5 0 0 0 .72.45l1.5-.75a1 1 0 0 1 .45-.1 8.56 8.56 0 0 0 1.33.1C11.5 17.7 11 16.9 11 16c0-2.76 2.69-5 6-5 .34 0 .67.02 1 .07A6.5 6.5 0 0 0 8.5 4z"/>
          <path d="M17 13c-2.21 0-4 1.57-4 3.5S14.79 20 17 20a5.4 5.4 0 0 0 1.08-.11.5.5 0 0 1 .35.06l1.07.54a.3.3 0 0 0 .43-.32l-.2-.9a.5.5 0 0 1 .14-.46C20.55 18.33 21 17.45 21 16.5 21 14.57 19.21 13 17 13z"/>
        </svg>
        前往微信扫码登录
      <% end %>

    </div>

    <!-- Footer -->
    <div class="px-8 py-4 border border-border border-t-0 bg-surface text-center">
      <p class="text-xs font-mono text-muted/50">
        登录即表示您同意我们的服务条款与隐私政策
      </p>
    </div>
  </div>
</div>
