<div class="container-lg py-12">
  <!-- Page Title -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold font-mono text-primary">个人资料</h1>
    <p class="text-secondary font-mono mt-2">查看和管理您的资料信息</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- 基本信息 -->
    <div class="card">
      <div class="card-body">
        <h2 class="text-lg font-semibold font-mono mb-6 flex items-center text-primary">
          <svg class="w-5 h-5 mr-2 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
          </svg>
          基本信息
        </h2>

        <div class="space-y-4">
          <div>
            <label class="form-label">姓名</label>
            <div class="text-primary font-mono font-medium"><%= @user.name.presence || "—" %></div>
          </div>

          <div>
            <label class="form-label">手机号</label>
            <div class="text-primary font-mono font-medium"><%= @user.phone.presence || "—" %></div>
          </div>

          <div>
            <label class="form-label">所在律所</label>
            <div class="text-primary font-mono font-medium"><%= @user.company.presence || "—" %></div>
          </div>

          <div>
            <label class="form-label">律所所在地区</label>
            <div class="text-primary font-mono font-medium">
              <% location = [@user.province, @user.city, @user.district].compact.reject(&:blank?).join(" ") %>
              <%= location.presence || "—" %>
            </div>
          </div>


        </div>

        <div class="mt-6">
          <%= link_to "编辑资料", edit_profile_path, class: "btn-primary" %>
        </div>
      </div>
    </div>

    <!-- 账号信息 -->
    <div class="card">
      <div class="card-body">
        <h2 class="text-lg font-semibold font-mono mb-6 flex items-center text-primary">
          <svg class="w-5 h-5 mr-2 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
          </svg>
          账号信息
        </h2>

        <div class="space-y-4">
          <div>
            <label class="form-label">注册时间</label>
            <div class="text-primary font-mono font-medium">
              <%= @user.created_at.strftime("%Y年%m月%d日") %>
            </div>
          </div>

          <div>
            <label class="form-label">微信 OpenID</label>
            <div class="text-muted font-mono text-xs truncate">
              <%= @user.wechat_openid.presence || "—" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 退出登录 -->
  <div class="mt-8 text-center">
    <%= button_to "退出登录", sign_out_path, method: :delete, class: "btn-ghost text-red-400 hover:text-red-300" %>
  </div>
</div>
